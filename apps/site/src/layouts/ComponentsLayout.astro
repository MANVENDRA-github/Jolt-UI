---
import Base from './Base.astro';
import { categoriesWithComponents } from '../lib/categories';

interface Props {
  title: string;
  description?: string;
  /** Widen the column to the chrome width (used by the gallery grid, not the demo pages). */
  wide?: boolean;
}
const { title, description, wide = false } = Astro.props;

const cats = categoriesWithComponents();
const path = Astro.url.pathname;
// /components/<slug>/<id> → the active category slug (null on the index itself).
const activeSlug = path.split('/')[2] ?? null;
---

<Base title={title} description={description} wide={wide}>
  <nav
    aria-label="Components"
    class="mb-8 flex flex-wrap gap-x-5 gap-y-1 border-b border-[color:var(--jolt-border)] pb-3 text-sm"
    data-pagefind-ignore
  >
    <a
      href="/components"
      class:list={[
        'transition-colors',
        path === '/components'
          ? 'font-medium text-[var(--jolt-text)]'
          : 'text-[var(--jolt-text-subtle)] hover:text-[var(--jolt-text)]',
      ]}
    >
      All
    </a>
    {
      cats.map((c) => (
        <a
          href={`/components#${c.slug}`}
          class:list={[
            'transition-colors',
            activeSlug === c.slug
              ? 'font-medium text-[var(--jolt-text)]'
              : 'text-[var(--jolt-text-subtle)] hover:text-[var(--jolt-text)]',
          ]}
        >
          {c.label}
        </a>
      ))
    }
  </nav>
  <slot />
</Base>
