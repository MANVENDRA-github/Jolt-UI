---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;

const docs = [
  { href: '/docs/getting-started', label: 'Getting Started' },
  { href: '/docs/theming', label: 'Theming' },
  { href: '/docs/accessibility', label: 'Accessibility' },
  { href: '/docs/contributing', label: 'Contributing' },
];
const path = Astro.url.pathname;
---

<Base title={title} description={description} width="prose">
  <nav
    aria-label="Documentation"
    class="mb-8 flex flex-wrap gap-x-5 gap-y-1 border-b border-[color:var(--jolt-border)] pb-3 text-sm"
    data-pagefind-ignore
  >
    {
      docs.map((d) => (
        <a
          href={d.href}
          class:list={[
            'transition-colors',
            path === d.href
              ? 'font-medium text-[var(--jolt-text)]'
              : 'text-[var(--jolt-text-subtle)] hover:text-[var(--jolt-text)]',
          ]}
        >
          {d.label}
        </a>
      ))
    }
  </nav>
  <article class="prose-jolt">
    <slot />
  </article>
</Base>

<style>
  /* Minimal prose typography (no @tailwindcss/typography plugin). The slotted
     children come from the page's scope, so target them with :global() inside the
     scoped .prose-jolt wrapper. */
  .prose-jolt :global(h1) {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }
  .prose-jolt :global(h2) {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    margin-top: 2.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-jolt :global(h3) {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.25rem;
  }
  .prose-jolt :global(p),
  .prose-jolt :global(ul),
  .prose-jolt :global(ol) {
    margin-top: 0.75rem;
    line-height: var(--leading-body);
    color: var(--jolt-text-muted);
  }
  .prose-jolt :global(ul),
  .prose-jolt :global(ol) {
    padding-left: 1.25rem;
  }
  .prose-jolt :global(ul) {
    list-style: disc;
  }
  .prose-jolt :global(ol) {
    list-style: decimal;
  }
  .prose-jolt :global(li) {
    margin-top: 0.25rem;
  }
  .prose-jolt :global(strong) {
    color: var(--jolt-text);
    font-weight: 600;
  }
  .prose-jolt :global(a) {
    color: var(--jolt-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-jolt :global(a:hover) {
    color: var(--jolt-accent-hover);
  }
  /* Inline code; reset inside expressive-code blocks (figure/pre) so it isn't double-styled. */
  .prose-jolt :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    border-radius: var(--radius-jolt-sm);
    background: var(--jolt-surface-sunken);
    border: 1px solid var(--jolt-border);
    color: var(--jolt-text);
    padding: 0.1rem 0.35rem;
  }
  .prose-jolt :global(figure code),
  .prose-jolt :global(pre code) {
    background: none;
    border: 0;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }
  .prose-jolt :global(table) {
    width: 100%;
    margin-top: 1rem;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .prose-jolt :global(th),
  .prose-jolt :global(td) {
    border-bottom: 1px solid var(--jolt-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .prose-jolt :global(th) {
    color: var(--jolt-text-subtle);
    font-weight: 600;
  }
</style>
