---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { SITE_NAME, SITE_DESCRIPTION, absoluteUrl, buildWebsiteJsonLd } from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  /** Path or absolute URL of the social preview image; defaults to the site-wide og.svg. */
  ogImage?: string;
  /** Set on non-indexable pages (e.g. the internal parity harness). */
  noindex?: boolean;
  /** Structured data; defaults to the site-wide WebSite JSON-LD. Pass `null` to omit. */
  jsonLd?: Record<string, unknown> | null;
}

const {
  title = SITE_NAME,
  description = SITE_DESCRIPTION,
  ogImage = '/og.svg',
  noindex = false,
  jsonLd,
} = Astro.props;

const site = Astro.site;
const canonical = absoluteUrl(site, Astro.url.pathname);
const ogImageUrl = absoluteUrl(site, ogImage);
const structuredData = jsonLd === null ? null : (jsonLd ?? buildWebsiteJsonLd(site));
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {
      structuredData && (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
      )
    }

    <script is:inline>
      // No-flash theme init before paint.
      const stored = localStorage.getItem('jolt-theme');
      if (stored) document.documentElement.dataset.theme = stored;
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <Nav />
    <main class="mx-auto w-full max-w-2xl flex-1 p-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>
