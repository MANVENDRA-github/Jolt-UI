---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { SITE_NAME, SITE_DESCRIPTION, absoluteUrl, buildWebsiteJsonLd } from '../lib/seo';
// Preload the body + display faces (latin, weight axis) so first paint isn't a swap.
// `?url` resolves to the fingerprinted asset path at build time.
import interWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import groteskWoff2 from '@fontsource-variable/space-grotesk/files/space-grotesk-latin-wght-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
  /** Path or absolute URL of the social preview image; defaults to the site-wide og.svg. */
  ogImage?: string;
  /** Set on non-indexable pages (e.g. the internal parity harness). */
  noindex?: boolean;
  /** Content column width: 'prose' (docs), 'default' (demo pages), 'wide' (gallery),
      or 'full' (the landing — full-bleed sections that manage their own inner column). */
  width?: 'prose' | 'default' | 'wide' | 'full';
  /** Structured data; defaults to the site-wide WebSite JSON-LD. Pass `null` to omit. */
  jsonLd?: Record<string, unknown> | null;
}

const {
  title = SITE_NAME,
  description = SITE_DESCRIPTION,
  ogImage = '/og.svg',
  noindex = false,
  width = 'default',
  jsonLd,
} = Astro.props;

// One shared max-width for the chrome + content column so they always align; the same
// horizontal padding on nav/main/footer keeps their content edges lined up at every size.
// 'full' bleeds main edge-to-edge (sections carry their own inner column) while the
// chrome keeps the wide column so nav/footer stay aligned with the landing's content.
const chromeW =
  width === 'wide' || width === 'full'
    ? 'max-w-[84rem]'
    : width === 'prose'
      ? 'max-w-2xl'
      : 'max-w-4xl';
const mainClasses =
  width === 'full'
    ? ['w-full flex-1']
    : ['mx-auto w-full flex-1 px-4 py-10 sm:px-6 lg:px-8', chromeW];

const site = Astro.site;
const canonical = absoluteUrl(site, Astro.url.pathname);
const ogImageUrl = absoluteUrl(site, ogImage);
const structuredData = jsonLd === null ? null : (jsonLd ?? buildWebsiteJsonLd(site));
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preload" href={interWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={groteskWoff2} as="font" type="font/woff2" crossorigin />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {
      structuredData && (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
      )
    }

    <script is:inline>
      // No-flash theme init before paint.
      const stored = localStorage.getItem('jolt-theme');
      if (stored) document.documentElement.dataset.theme = stored;
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <Nav maxW={chromeW} />
    <main class:list={mainClasses} data-pagefind-body={noindex ? undefined : true}>
      <slot />
    </main>
    <Footer maxW={chromeW} />
  </body>
</html>
