---
// Internal E2E harness: every component, same text, three frameworks — the
// Playwright parity test asserts the frameworks render identically.
import Base from '../../layouts/Base.astro';
import {
  SplitText as RSplit,
  BlurIn as RBlur,
  Wave as RWave,
  GradientText as RGrad,
  ShinyText as RShiny,
  Typewriter as RType,
  RotatingWords as RRot,
  CountUp as RCount,
  Scramble as RScramble,
  ScrollVelocity as RScrollVel,
  Spinner as RSpinner,
  DotBounce as RDotBounce,
  Bars as RBars,
  Pulse as RPulse,
  Ripple as RRipple,
  Grid as RGrid,
  ProgressBar as RProgressBar,
  Shimmer as RShimmer,
  Glow as RGlow,
  Gradient as RGradient,
  Sweep as RSweep,
  BorderDraw as RBorderDraw,
  Tactile as RTactile,
  Spotlight as RSpotlight,
  Tilt as RTilt,
  ShineBorder as RShineBorder,
  FadeUp as RFadeUp,
  FlipIn as RFlipIn,
  Neon as RNeon,
  GlitchText as RGlitchText,
  TrueFocus as RTrueFocus,
  CircularText as RCircularText,
  Glare as RGlare,
  BorderGlow as RBorderGlow,
  StarBorder as RStarBorder,
  // gen:react
} from '@jolt/react';
import {
  SplitText as VSplit,
  BlurIn as VBlur,
  Wave as VWave,
  GradientText as VGrad,
  ShinyText as VShiny,
  Typewriter as VType,
  RotatingWords as VRot,
  CountUp as VCount,
  Scramble as VScramble,
  ScrollVelocity as VScrollVel,
  Spinner as VSpinner,
  DotBounce as VDotBounce,
  Bars as VBars,
  Pulse as VPulse,
  Ripple as VRipple,
  Grid as VGrid,
  ProgressBar as VProgressBar,
  Shimmer as VShimmer,
  Glow as VGlow,
  Gradient as VGradient,
  Sweep as VSweep,
  BorderDraw as VBorderDraw,
  Tactile as VTactile,
  Spotlight as VSpotlight,
  Tilt as VTilt,
  ShineBorder as VShineBorder,
  FadeUp as VFadeUp,
  FlipIn as VFlipIn,
  Neon as VNeon,
  GlitchText as VGlitchText,
  TrueFocus as VTrueFocus,
  CircularText as VCircularText,
  Glare as VGlare,
  BorderGlow as VBorderGlow,
  StarBorder as VStarBorder,
  // gen:vue
} from '@jolt/vue';
import {
  SplitText as SSplit,
  BlurIn as SBlur,
  Wave as SWave,
  GradientText as SGrad,
  ShinyText as SShiny,
  Typewriter as SType,
  RotatingWords as SRot,
  CountUp as SCount,
  Scramble as SScramble,
  ScrollVelocity as SScrollVel,
  Spinner as SSpinner,
  DotBounce as SDotBounce,
  Bars as SBars,
  Pulse as SPulse,
  Ripple as SRipple,
  Grid as SGrid,
  ProgressBar as SProgressBar,
  Shimmer as SShimmer,
  Glow as SGlow,
  Gradient as SGradient,
  Sweep as SSweep,
  BorderDraw as SBorderDraw,
  Tactile as STactile,
  Spotlight as SSpotlight,
  Tilt as STilt,
  ShineBorder as SShineBorder,
  FadeUp as SFadeUp,
  FlipIn as SFlipIn,
  Neon as SNeon,
  GlitchText as SGlitchText,
  TrueFocus as STrueFocus,
  CircularText as SCircularText,
  Glare as SGlare,
  BorderGlow as SBorderGlow,
  StarBorder as SStarBorder,
  // gen:svelte
} from '@jolt/svelte';

const TEXT = 'Jolt UI';
---

<Base title="parity harness" noindex>
  <div class="space-y-6 text-3xl font-bold">
    <div data-testid="split-text-react"><RSplit text={TEXT} client:load /></div>
    <div data-testid="split-text-vue"><VSplit text={TEXT} client:load /></div>
    <div data-testid="split-text-svelte"><SSplit text={TEXT} client:load /></div>
    <div data-testid="blur-in-react"><RBlur text={TEXT} /></div>
    <div data-testid="blur-in-vue"><VBlur text={TEXT} /></div>
    <div data-testid="blur-in-svelte"><SBlur text={TEXT} /></div>
    <div data-testid="wave-react"><RWave text={TEXT} /></div>
    <div data-testid="wave-vue"><VWave text={TEXT} /></div>
    <div data-testid="wave-svelte"><SWave text={TEXT} /></div>
    <div data-testid="gradient-text-react"><RGrad text={TEXT} /></div>
    <div data-testid="gradient-text-vue"><VGrad text={TEXT} /></div>
    <div data-testid="gradient-text-svelte"><SGrad text={TEXT} /></div>
    <div data-testid="shiny-text-react"><RShiny text={TEXT} /></div>
    <div data-testid="shiny-text-vue"><VShiny text={TEXT} /></div>
    <div data-testid="shiny-text-svelte"><SShiny text={TEXT} /></div>
    <div data-testid="typewriter-react"><RType text={TEXT} /></div>
    <div data-testid="typewriter-vue"><VType text={TEXT} /></div>
    <div data-testid="typewriter-svelte"><SType text={TEXT} /></div>
    <div data-testid="rotating-words-react"><RRot words={['Jolt', 'UI']} /></div>
    <div data-testid="rotating-words-vue"><VRot words={['Jolt', 'UI']} /></div>
    <div data-testid="rotating-words-svelte"><SRot words={['Jolt', 'UI']} /></div>
    <div data-testid="count-up-react"><RCount to={100} client:load /></div>
    <div data-testid="count-up-vue"><VCount to={100} client:load /></div>
    <div data-testid="count-up-svelte"><SCount to={100} client:load /></div>
    <div data-testid="scramble-react"><RScramble text={TEXT} client:load /></div>
    <div data-testid="scramble-vue"><VScramble text={TEXT} client:load /></div>
    <div data-testid="scramble-svelte"><SScramble text={TEXT} client:load /></div>
    <div data-testid="scroll-velocity-react"><RScrollVel text={TEXT} client:load /></div>
    <div data-testid="scroll-velocity-vue"><VScrollVel text={TEXT} client:load /></div>
    <div data-testid="scroll-velocity-svelte"><SScrollVel text={TEXT} client:load /></div>
    <div data-testid="spinner-react"><RSpinner /></div>
    <div data-testid="spinner-vue"><VSpinner /></div>
    <div data-testid="spinner-svelte"><SSpinner /></div>
    <div data-testid="dot-bounce-react"><RDotBounce /></div>
    <div data-testid="dot-bounce-vue"><VDotBounce /></div>
    <div data-testid="dot-bounce-svelte"><SDotBounce /></div>
    <div data-testid="bars-react"><RBars /></div>
    <div data-testid="bars-vue"><VBars /></div>
    <div data-testid="bars-svelte"><SBars /></div>
    <div data-testid="pulse-react"><RPulse /></div>
    <div data-testid="pulse-vue"><VPulse /></div>
    <div data-testid="pulse-svelte"><SPulse /></div>
    <div data-testid="ripple-react"><RRipple /></div>
    <div data-testid="ripple-vue"><VRipple /></div>
    <div data-testid="ripple-svelte"><SRipple /></div>
    <div data-testid="grid-react"><RGrid /></div>
    <div data-testid="grid-vue"><VGrid /></div>
    <div data-testid="grid-svelte"><SGrid /></div>
    <div data-testid="progress-bar-react"><RProgressBar /></div>
    <div data-testid="progress-bar-vue"><VProgressBar /></div>
    <div data-testid="progress-bar-svelte"><SProgressBar /></div>
    <div data-testid="shimmer-react"><RShimmer /></div>
    <div data-testid="shimmer-vue"><VShimmer /></div>
    <div data-testid="shimmer-svelte"><SShimmer /></div>
    <div data-testid="glow-react"><RGlow /></div>
    <div data-testid="glow-vue"><VGlow /></div>
    <div data-testid="glow-svelte"><SGlow /></div>
    <div data-testid="gradient-react"><RGradient /></div>
    <div data-testid="gradient-vue"><VGradient /></div>
    <div data-testid="gradient-svelte"><SGradient /></div>
    <div data-testid="sweep-react"><RSweep /></div>
    <div data-testid="sweep-vue"><VSweep /></div>
    <div data-testid="sweep-svelte"><SSweep /></div>
    <div data-testid="border-draw-react"><RBorderDraw /></div>
    <div data-testid="border-draw-vue"><VBorderDraw /></div>
    <div data-testid="border-draw-svelte"><SBorderDraw /></div>
    <div data-testid="tactile-react"><RTactile /></div>
    <div data-testid="tactile-vue"><VTactile /></div>
    <div data-testid="tactile-svelte"><STactile /></div>
    <div data-testid="spotlight-react"><RSpotlight client:load>{TEXT}</RSpotlight></div>
    <div data-testid="spotlight-vue"><VSpotlight client:load>{TEXT}</VSpotlight></div>
    <div data-testid="spotlight-svelte"><SSpotlight client:load>{TEXT}</SSpotlight></div>
    <div data-testid="tilt-react"><RTilt client:load>{TEXT}</RTilt></div>
    <div data-testid="tilt-vue"><VTilt client:load>{TEXT}</VTilt></div>
    <div data-testid="tilt-svelte"><STilt client:load>{TEXT}</STilt></div>
    <div data-testid="shine-border-react"><RShineBorder>{TEXT}</RShineBorder></div>
    <div data-testid="shine-border-vue"><VShineBorder>{TEXT}</VShineBorder></div>
    <div data-testid="shine-border-svelte"><SShineBorder>{TEXT}</SShineBorder></div>
    <div data-testid="fade-up-react"><RFadeUp text="Jolt UI" /></div>
    <div data-testid="fade-up-vue"><VFadeUp text="Jolt UI" /></div>
    <div data-testid="fade-up-svelte"><SFadeUp text="Jolt UI" /></div>
    <div data-testid="flip-in-react"><RFlipIn text="Jolt UI" /></div>
    <div data-testid="flip-in-vue"><VFlipIn text="Jolt UI" /></div>
    <div data-testid="flip-in-svelte"><SFlipIn text="Jolt UI" /></div>
    <div data-testid="neon-react"><RNeon text="Jolt UI" /></div>
    <div data-testid="neon-vue"><VNeon text="Jolt UI" /></div>
    <div data-testid="neon-svelte"><SNeon text="Jolt UI" /></div>
    <div data-testid="glitch-text-react"><RGlitchText text="Jolt UI" /></div>
    <div data-testid="glitch-text-vue"><VGlitchText text="Jolt UI" /></div>
    <div data-testid="glitch-text-svelte"><SGlitchText text="Jolt UI" /></div>
    <div data-testid="true-focus-react"><RTrueFocus text="Jolt UI" /></div>
    <div data-testid="true-focus-vue"><VTrueFocus text="Jolt UI" /></div>
    <div data-testid="true-focus-svelte"><STrueFocus text="Jolt UI" /></div>
    <div data-testid="circular-text-react"><RCircularText text="Jolt UI" /></div>
    <div data-testid="circular-text-vue"><VCircularText text="Jolt UI" /></div>
    <div data-testid="circular-text-svelte"><SCircularText text="Jolt UI" /></div>
    <div data-testid="glare-react"><RGlare client:load>{TEXT}</RGlare></div>
    <div data-testid="glare-vue"><VGlare client:load>{TEXT}</VGlare></div>
    <div data-testid="glare-svelte"><SGlare client:load>{TEXT}</SGlare></div>
    <div data-testid="border-glow-react"><RBorderGlow client:load>{TEXT}</RBorderGlow></div>
    <div data-testid="border-glow-vue"><VBorderGlow client:load>{TEXT}</VBorderGlow></div>
    <div data-testid="border-glow-svelte"><SBorderGlow client:load>{TEXT}</SBorderGlow></div>
    <div data-testid="star-border-react"><RStarBorder label="Jolt UI" /></div>
    <div data-testid="star-border-vue"><VStarBorder label="Jolt UI" /></div>
    <div data-testid="star-border-svelte"><SStarBorder label="Jolt UI" /></div>
    {/* gen:cells */}
  </div>
</Base>
