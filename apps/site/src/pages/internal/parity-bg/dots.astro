---
// Internal E2E harness — one WebGL background, three frameworks, on its OWN page so
// only 3 live WebGL contexts exist per page load. The parity spec visits one of these
// per background (newPage/close) to stay under Chromium's context cap (D-032).
import Base from '../../../layouts/Base.astro';
import { Dots as RDots } from '@jolt/react';
import { Dots as VDots } from '@jolt/vue';
import { Dots as SDots } from '@jolt/svelte';
---

<Base title="parity harness — dots" noindex>
  <div class="space-y-6">
    <div data-testid="dots-react" class="relative h-40 w-64"><RDots client:load /></div>
    <div data-testid="dots-vue" class="relative h-40 w-64"><VDots client:load /></div>
    <div data-testid="dots-svelte" class="relative h-40 w-64"><SDots client:load /></div>
  </div>
</Base>
