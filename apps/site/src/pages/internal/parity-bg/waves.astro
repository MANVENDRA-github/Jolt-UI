---
// Internal E2E harness — one WebGL background, three frameworks, on its OWN page so
// only 3 live WebGL contexts exist per page load. The parity spec visits one of these
// per background (newPage/close) to stay under Chromium's context cap (D-032).
import Base from '../../../layouts/Base.astro';
import { Waves as RWaves } from '@jolt/react';
import { Waves as VWaves } from '@jolt/vue';
import { Waves as SWaves } from '@jolt/svelte';
---

<Base title="parity harness — waves" noindex>
  <div class="space-y-6">
    <div data-testid="waves-react" class="relative h-40 w-64"><RWaves client:load /></div>
    <div data-testid="waves-vue" class="relative h-40 w-64"><VWaves client:load /></div>
    <div data-testid="waves-svelte" class="relative h-40 w-64"><SWaves client:load /></div>
  </div>
</Base>
