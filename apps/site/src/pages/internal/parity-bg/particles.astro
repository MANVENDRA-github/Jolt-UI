---
// Internal E2E harness — one WebGL background, three frameworks, on its OWN page so
// only 3 live WebGL contexts exist per page load. The parity spec visits one of these
// per background (newPage/close) to stay under Chromium's context cap (D-032).
import Base from '../../../layouts/Base.astro';
import { Particles as RParticles } from '@jolt/react';
import { Particles as VParticles } from '@jolt/vue';
import { Particles as SParticles } from '@jolt/svelte';
---

<Base title="parity harness — particles" noindex>
  <div class="space-y-6">
    <div data-testid="particles-react" class="relative h-40 w-64"><RParticles client:load /></div>
    <div data-testid="particles-vue" class="relative h-40 w-64"><VParticles client:load /></div>
    <div data-testid="particles-svelte" class="relative h-40 w-64"><SParticles client:load /></div>
  </div>
</Base>
