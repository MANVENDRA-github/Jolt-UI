---
// Internal E2E harness — one WebGL background, three frameworks, on its OWN page so
// only 3 live WebGL contexts exist per page load. The parity spec visits one of these
// per background (newPage/close) to stay under Chromium's context cap (D-032).
import Base from '../../../layouts/Base.astro';
import { Globe as RGlobe } from '@jolt/react';
import { Globe as VGlobe } from '@jolt/vue';
import { Globe as SGlobe } from '@jolt/svelte';
---

<Base title="parity harness — globe" noindex>
  <div class="space-y-6">
    <div data-testid="globe-react" class="relative h-40 w-64"><RGlobe client:load /></div>
    <div data-testid="globe-vue" class="relative h-40 w-64"><VGlobe client:load /></div>
    <div data-testid="globe-svelte" class="relative h-40 w-64"><SGlobe client:load /></div>
  </div>
</Base>
