---
// Internal E2E harness — one WebGL background, three frameworks, on its OWN page so
// only 3 live WebGL contexts exist per page load. The parity spec visits one of these
// per background (newPage/close) to stay under Chromium's context cap (D-032).
import Base from '../../../layouts/Base.astro';
import { LightRays as RLightRays } from '@jolt/react';
import { LightRays as VLightRays } from '@jolt/vue';
import { LightRays as SLightRays } from '@jolt/svelte';
---

<Base title="parity harness — light-rays" noindex>
  <div class="space-y-6">
    <div data-testid="light-rays-react" class="relative h-40 w-64"><RLightRays client:load /></div>
    <div data-testid="light-rays-vue" class="relative h-40 w-64"><VLightRays client:load /></div>
    <div data-testid="light-rays-svelte" class="relative h-40 w-64"><SLightRays client:load /></div>
  </div>
</Base>
