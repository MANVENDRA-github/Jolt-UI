---
// Internal E2E harness — one WebGL background, three frameworks, on its OWN page so
// only 3 live WebGL contexts exist per page load. The parity spec visits one of these
// per background (newPage/close) to stay under Chromium's context cap (D-032).
import Base from '../../../layouts/Base.astro';
import { Aurora as RAurora } from '@jolt/react';
import { Aurora as VAurora } from '@jolt/vue';
import { Aurora as SAurora } from '@jolt/svelte';
---

<Base title="parity harness — aurora" noindex>
  <div class="space-y-6">
    <div data-testid="aurora-react" class="relative h-40 w-64"><RAurora client:load /></div>
    <div data-testid="aurora-vue" class="relative h-40 w-64"><VAurora client:load /></div>
    <div data-testid="aurora-svelte" class="relative h-40 w-64"><SAurora client:load /></div>
  </div>
</Base>
