---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { GradientText as ReactGradientText } from '@jolt/react';
import { GradientText as VueGradientText } from '@jolt/vue';
import { GradientText as SvelteGradientText } from '@jolt/svelte';
import { gradientTextSchema, gradientTextMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/GradientText/GradientText.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/GradientText/GradientText.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/GradientText/GradientText.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="GradientText — Jolt UI"
  description="A flowing multi-color gradient clipped to the text — CSS-only, for React, Vue, and Svelte."
>
  <Breadcrumbs id="gradient-text" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">GradientText</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A flowing multi-color gradient clipped to the text — CSS-only, three frameworks.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="gradient-text">
      <div class="text-4xl font-bold" slot="react">
        <ReactGradientText text="Gradient in motion" />
      </div>
      <div class="text-4xl font-bold" slot="vue"><VueGradientText text="Gradient in motion" /></div>
      <div class="text-4xl font-bold" slot="svelte">
        <SvelteGradientText text="Gradient in motion" />
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={gradientTextMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Pure CSS animation; the skin builds the gradient from <code class={codePill}>colors</code>.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={gradientTextSchema} />
  <ComponentPager id="gradient-text" />
</ComponentsLayout>
