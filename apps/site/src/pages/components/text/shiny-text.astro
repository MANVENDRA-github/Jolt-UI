---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { ShinyText as ReactShinyText } from '@jolt/react';
import { ShinyText as VueShinyText } from '@jolt/vue';
import { ShinyText as SvelteShinyText } from '@jolt/svelte';
import { shinyTextSchema, shinyTextMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/ShinyText/ShinyText.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/ShinyText/ShinyText.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/ShinyText/ShinyText.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
---

<ComponentsLayout
  title="ShinyText — Jolt UI"
  description="A sheen sweeping across muted text — CSS-only, for React, Vue, and Svelte."
>
  <Breadcrumbs id="shiny-text" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">ShinyText</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A sheen sweeping across muted text — CSS-only, three frameworks.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="shiny-text">
      <div class="text-4xl font-bold" slot="react"><ReactShinyText text="Just shining" /></div>
      <div class="text-4xl font-bold" slot="vue"><VueShinyText text="Just shining" /></div>
      <div class="text-4xl font-bold" slot="svelte"><SvelteShinyText text="Just shining" /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={shinyTextMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Pure CSS animation; base + highlight colors are themeable via CSS variables.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={shinyTextSchema} />
  <ComponentPager id="shiny-text" />
</ComponentsLayout>
