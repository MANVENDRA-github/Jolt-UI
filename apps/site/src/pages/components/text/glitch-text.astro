---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { GlitchText as ReactGlitchText } from '@jolt/react';
import { GlitchText as VueGlitchText } from '@jolt/vue';
import { GlitchText as SvelteGlitchText } from '@jolt/svelte';
import { glitchTextSchema, glitchTextMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/GlitchText/GlitchText.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/GlitchText/GlitchText.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/GlitchText/GlitchText.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
---

<ComponentsLayout title="GlitchText — Jolt UI">
  <Breadcrumbs id="glitch-text" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">GlitchText</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">Chromatic split and jitter, glitching on a loop</p>

  <div class="mt-8">
    <FrameworkSwitcher id="glitch-text">
      <div class="text-3xl font-semibold" slot="react"><ReactGlitchText text="Glitch Text" /></div>
      <div class="text-3xl font-semibold" slot="vue"><VueGlitchText text="Glitch Text" /></div>
      <div class="text-3xl font-semibold" slot="svelte">
        <SvelteGlitchText text="Glitch Text" />
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={glitchTextMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={glitchTextSchema} />
  <ComponentPager id="glitch-text" />
</ComponentsLayout>
