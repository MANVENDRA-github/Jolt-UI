---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { ScrollVelocity as ReactScrollVelocity } from '@jolt/react';
import { ScrollVelocity as VueScrollVelocity } from '@jolt/vue';
import { ScrollVelocity as SvelteScrollVelocity } from '@jolt/svelte';
import { scrollVelocitySchema, scrollVelocityMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/ScrollVelocity/ScrollVelocity.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/ScrollVelocity/ScrollVelocity.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/ScrollVelocity/ScrollVelocity.svelte?raw';

const marquee = 'Animated components for React · Vue · Svelte ·';
const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
---

<ComponentsLayout
  title="ScrollVelocity — Jolt UI"
  description="A marquee whose speed and direction react to scroll velocity (GSAP) — for React, Vue, and Svelte."
>
  <Breadcrumbs id="scroll-velocity" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">ScrollVelocity</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A marquee whose speed and direction react to scroll velocity — GSAP, three frameworks. <span
      class="text-[var(--jolt-text-subtle)]">(Scroll the page to feel it.)</span
    >
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="scroll-velocity">
      <div class="text-4xl font-bold" slot="react">
        <ReactScrollVelocity text={marquee} client:visible />
      </div>
      <div class="text-4xl font-bold" slot="vue">
        <VueScrollVelocity text={marquee} client:visible />
      </div>
      <div class="text-4xl font-bold" slot="svelte">
        <SvelteScrollVelocity text={marquee} client:visible />
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={scrollVelocityMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={scrollVelocitySchema} />
  <ComponentPager id="scroll-velocity" />
</ComponentsLayout>
