---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { CircularText as ReactCircularText } from '@jolt/react';
import { CircularText as VueCircularText } from '@jolt/vue';
import { CircularText as SvelteCircularText } from '@jolt/svelte';
import { circularTextSchema, circularTextMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/CircularText/CircularText.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/CircularText/CircularText.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/CircularText/CircularText.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
// The glyphs share the ring's circumference, so type size and radius are tuned together:
// 26 segments around r=86 leaves ~21px of arc each, which a tracked-out `text-sm` fills.
const ring = 'flex justify-center py-4 text-sm font-semibold tracking-[0.2em]';
---

<ComponentsLayout title="CircularText — Jolt UI">
  <Breadcrumbs id="circular-text" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">CircularText</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">Text laid around a circle, turning slowly</p>

  <div class="mt-8">
    <FrameworkSwitcher id="circular-text">
      <div class={ring} slot="react">
        <ReactCircularText text="CIRCULAR TEXT · JOLT UI · " radius={86} />
      </div>
      <div class={ring} slot="vue">
        <VueCircularText text="CIRCULAR TEXT · JOLT UI · " radius={86} />
      </div>
      <div class={ring} slot="svelte">
        <SvelteCircularText text="CIRCULAR TEXT · JOLT UI · " radius={86} />
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={circularTextMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={circularTextSchema} />
  <ComponentPager id="circular-text" />
</ComponentsLayout>
