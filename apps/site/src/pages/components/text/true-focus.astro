---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { TrueFocus as ReactTrueFocus } from '@jolt/react';
import { TrueFocus as VueTrueFocus } from '@jolt/vue';
import { TrueFocus as SvelteTrueFocus } from '@jolt/svelte';
import { trueFocusSchema, trueFocusMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/TrueFocus/TrueFocus.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/TrueFocus/TrueFocus.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/TrueFocus/TrueFocus.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
---

<ComponentsLayout title="TrueFocus — Jolt UI">
  <Breadcrumbs id="true-focus" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">TrueFocus</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">A sharp focus sweeps across softly blurred text</p>

  <div class="mt-8">
    <FrameworkSwitcher id="true-focus">
      <div class="text-3xl font-semibold" slot="react">
        <ReactTrueFocus text="True Focus" blur={6} />
      </div>
      <div class="text-3xl font-semibold" slot="vue">
        <VueTrueFocus text="True Focus" blur={6} />
      </div>
      <div class="text-3xl font-semibold" slot="svelte">
        <SvelteTrueFocus text="True Focus" blur={6} />
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={trueFocusMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={trueFocusSchema} />
  <ComponentPager id="true-focus" />
</ComponentsLayout>
