---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { FlipIn as ReactFlipIn } from '@jolt/react';
import { FlipIn as VueFlipIn } from '@jolt/vue';
import { FlipIn as SvelteFlipIn } from '@jolt/svelte';
import { flipInSchema, flipInMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/FlipIn/FlipIn.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/FlipIn/FlipIn.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/FlipIn/FlipIn.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
---

<ComponentsLayout title="FlipIn — Jolt UI">
  <Breadcrumbs id="flip-in" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">FlipIn</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">Per-character 3D flip-in entrance</p>

  <div class="mt-8">
    <FrameworkSwitcher id="flip-in">
      <div class="text-3xl font-semibold" slot="react"><ReactFlipIn text="Flip In" /></div>
      <div class="text-3xl font-semibold" slot="vue"><VueFlipIn text="Flip In" /></div>
      <div class="text-3xl font-semibold" slot="svelte"><SvelteFlipIn text="Flip In" /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={flipInMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={flipInSchema} />
  <ComponentPager id="flip-in" />
</ComponentsLayout>
