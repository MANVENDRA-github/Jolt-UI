---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { FadeUp as ReactFadeUp } from '@jolt/react';
import { FadeUp as VueFadeUp } from '@jolt/vue';
import { FadeUp as SvelteFadeUp } from '@jolt/svelte';
import { fadeUpSchema, fadeUpMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/FadeUp/FadeUp.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/FadeUp/FadeUp.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/FadeUp/FadeUp.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
---

<ComponentsLayout title="FadeUp — Jolt UI">
  <Breadcrumbs id="fade-up" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">FadeUp</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">Per-character rise + fade-in entrance</p>

  <div class="mt-8">
    <FrameworkSwitcher id="fade-up">
      <div class="text-3xl font-semibold" slot="react"><ReactFadeUp text="Fade Up" /></div>
      <div class="text-3xl font-semibold" slot="vue"><VueFadeUp text="Fade Up" /></div>
      <div class="text-3xl font-semibold" slot="svelte"><SvelteFadeUp text="Fade Up" /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={fadeUpMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={fadeUpSchema} />
  <ComponentPager id="fade-up" />
</ComponentsLayout>
