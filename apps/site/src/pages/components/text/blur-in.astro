---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { BlurIn as ReactBlurIn } from '@jolt/react';
import { BlurIn as VueBlurIn } from '@jolt/vue';
import { BlurIn as SvelteBlurIn } from '@jolt/svelte';
import { blurInSchema, blurInMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/BlurIn/BlurIn.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/BlurIn/BlurIn.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/BlurIn/BlurIn.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
---

<ComponentsLayout
  title="BlurIn — Jolt UI"
  description="A per-character fade + de-blur reveal — CSS-only, for React, Vue, and Svelte."
>
  <Breadcrumbs id="blur-in" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">BlurIn</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A per-character fade + de-blur reveal — CSS-only, three frameworks.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="blur-in">
      <div class="text-3xl font-semibold" slot="react"><ReactBlurIn text="Blur into focus" /></div>
      <div class="text-3xl font-semibold" slot="vue"><VueBlurIn text="Blur into focus" /></div>
      <div class="text-3xl font-semibold" slot="svelte">
        <SvelteBlurIn text="Blur into focus" />
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={blurInMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Pure CSS animation; the skin only renders the split segments.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={blurInSchema} />
  <ComponentPager id="blur-in" />
</ComponentsLayout>
