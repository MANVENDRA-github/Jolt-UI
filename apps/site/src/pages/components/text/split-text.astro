---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { SplitText as ReactSplitText } from '@jolt/react';
import { SplitText as VueSplitText } from '@jolt/vue';
import { SplitText as SvelteSplitText } from '@jolt/svelte';
import { splitTextSchema, splitTextMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/SplitText/SplitText.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/SplitText/SplitText.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/SplitText/SplitText.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
---

<ComponentsLayout
  title="SplitText — Jolt UI"
  description="A staggered character/word reveal with GSAP — for React, Vue, and Svelte."
>
  <Breadcrumbs id="split-text" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">SplitText</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A staggered character/word reveal — one design language, three frameworks.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="split-text">
      <div class="text-3xl font-semibold" slot="react">
        <ReactSplitText text="Animated with React" client:visible />
      </div>
      <div class="text-3xl font-semibold" slot="vue">
        <VueSplitText text="Animated with Vue" client:visible />
      </div>
      <div class="text-3xl font-semibold" slot="svelte">
        <SvelteSplitText text="Animated with Svelte" client:visible />
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={splitTextMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={splitTextSchema} />
  <ComponentPager id="split-text" />
</ComponentsLayout>
