---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Typewriter as ReactTypewriter } from '@jolt/react';
import { Typewriter as VueTypewriter } from '@jolt/vue';
import { Typewriter as SvelteTypewriter } from '@jolt/svelte';
import { typewriterSchema, typewriterMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Typewriter/Typewriter.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Typewriter/Typewriter.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Typewriter/Typewriter.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Typewriter — Jolt UI"
  description="A character-by-character reveal with a blinking caret — CSS-only, for React, Vue, and Svelte."
>
  <Breadcrumbs id="typewriter" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Typewriter</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A character-by-character reveal with a blinking caret — CSS-only, three frameworks.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="typewriter">
      <div class="text-4xl font-bold" slot="react">
        <ReactTypewriter text="Type it out with Jolt" />
      </div>
      <div class="text-4xl font-bold" slot="vue">
        <VueTypewriter text="Type it out with Jolt" />
      </div>
      <div class="text-4xl font-bold" slot="svelte">
        <SvelteTypewriter text="Type it out with Jolt" />
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={typewriterMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Pure CSS animation; the skin sets the character count from <code class={codePill}>text</code> and
      a monospace font lands each step on a character.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={typewriterSchema} />
  <ComponentPager id="typewriter" />
</ComponentsLayout>
