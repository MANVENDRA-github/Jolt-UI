---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Scramble as ReactScramble } from '@jolt/react';
import { Scramble as VueScramble } from '@jolt/vue';
import { Scramble as SvelteScramble } from '@jolt/svelte';
import { scrambleSchema, scrambleMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Scramble/Scramble.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Scramble/Scramble.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Scramble/Scramble.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
---

<ComponentsLayout
  title="Scramble — Jolt UI"
  description="Text that decodes from a churn of characters with GSAP — for React, Vue, and Svelte."
>
  <Breadcrumbs id="scramble" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Scramble</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    Text that decodes into place from a churn of characters — GSAP, three frameworks.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="scramble">
      <div class="text-3xl font-semibold" slot="react">
        <ReactScramble text="Decoded by Jolt" client:visible />
      </div>
      <div class="text-3xl font-semibold" slot="vue">
        <VueScramble text="Decoded by Jolt" client:visible />
      </div>
      <div class="text-3xl font-semibold" slot="svelte">
        <SvelteScramble text="Decoded by Jolt" client:visible />
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={scrambleMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={scrambleSchema} />
  <ComponentPager id="scramble" />
</ComponentsLayout>
