---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Grid as ReactGrid } from '@jolt/react';
import { Grid as VueGrid } from '@jolt/vue';
import { Grid as SvelteGrid } from '@jolt/svelte';
import { gridSchema, gridMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Grid/Grid.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Grid/Grid.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Grid/Grid.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'flex h-32 w-full items-center justify-center rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Grid — Jolt UI"
  description="A 3×3 grid loader pulsing in a diagonal wave — CSS-only, for React, Vue, and Svelte."
>
  <Breadcrumbs id="grid" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Grid</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A 3×3 grid of squares pulsing in a diagonal wave, pure CSS — one design language, three
    frameworks. It exposes <code class={codePill}>role="status"</code> with an accessible label, and pauses
    to a static grid under reduced-motion.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="grid">
      <div class={previewBox} slot="react"><ReactGrid /></div>
      <div class={previewBox} slot="vue"><VueGrid /></div>
      <div class={previewBox} slot="svelte"><SvelteGrid /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={gridMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Pure CSS; color, size &amp; speed are props.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={gridSchema} />
  <ComponentPager id="grid" />
</ComponentsLayout>
