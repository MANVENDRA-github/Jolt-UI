---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Ripple as ReactRipple } from '@jolt/react';
import { Ripple as VueRipple } from '@jolt/vue';
import { Ripple as SvelteRipple } from '@jolt/svelte';
import { rippleSchema, rippleMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Ripple/Ripple.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Ripple/Ripple.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Ripple/Ripple.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'flex h-32 w-full items-center justify-center rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Ripple — Jolt UI"
  description="A Material-style ripple loader — concentric expanding rings, CSS-only, for React, Vue, and Svelte."
>
  <Breadcrumbs id="ripple" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Ripple</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    Two concentric rings expanding from the center (Material-style), pure CSS — one design language,
    three frameworks. It exposes <code class={codePill}>role="status"</code> with an accessible label,
    and pauses to a static ring under reduced-motion.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="ripple">
      <div class={previewBox} slot="react"><ReactRipple /></div>
      <div class={previewBox} slot="vue"><VueRipple /></div>
      <div class={previewBox} slot="svelte"><SvelteRipple /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={rippleMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Pure CSS; color, size &amp; speed are props.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={rippleSchema} />
  <ComponentPager id="ripple" />
</ComponentsLayout>
