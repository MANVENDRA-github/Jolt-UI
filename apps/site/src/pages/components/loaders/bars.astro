---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import { Bars as ReactBars } from '@jolt/react';
import { Bars as VueBars } from '@jolt/vue';
import { Bars as SvelteBars } from '@jolt/svelte';
import { propsTable, barsSchema, barsMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Bars/Bars.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Bars/Bars.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Bars/Bars.svelte?raw';

const props = propsTable(barsSchema);
const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'flex h-32 w-full items-center justify-center rounded-lg border border-white/10 bg-black/20';
---

<ComponentsLayout
  title="Bars — Jolt UI"
  description="Equalizer-style bars — a CSS-only loader for React, Vue, and Svelte."
>
  <h1 class="text-3xl font-bold">Bars</h1>
  <p class="mt-2 opacity-80">
    Five equalizer bars pulsing in sequence, pure CSS — one design language, three frameworks. It
    exposes <code class="rounded bg-white/10 px-1">role="status"</code> with an accessible label, and
    pauses under reduced-motion.
  </p>

  <section class="mt-10 space-y-8">
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">React</h2>
      <div class={previewBox}><ReactBars /></div>
    </div>
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">Vue</h2>
      <div class={previewBox}><VueBars /></div>
    </div>
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">Svelte</h2>
      <div class={previewBox}><SvelteBars /></div>
    </div>
  </section>

  <InstallBlock meta={barsMeta} />

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm opacity-70">Pure CSS; color, size &amp; speed are props.</p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Props</h2>
    <table class="mt-3 w-full border-collapse text-left text-sm">
      <thead>
        <tr class="border-b border-white/15">
          <th class="py-2 pr-4 font-semibold">Prop</th>
          <th class="py-2 pr-4 font-semibold">Type</th>
          <th class="py-2 pr-4 font-semibold">Default</th>
          <th class="py-2 font-semibold">Description</th>
        </tr>
      </thead>
      <tbody>
        {
          props.map((p) => (
            <tr class="border-b border-white/10">
              <td class="py-2 pr-4 font-mono">{p.name}</td>
              <td class="py-2 pr-4 font-mono opacity-80">{p.type}</td>
              <td class="py-2 pr-4 font-mono opacity-80">{p.default ?? 'required'}</td>
              <td class="py-2 opacity-80">{p.description}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>
</ComponentsLayout>
