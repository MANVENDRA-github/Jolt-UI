---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Bars as ReactBars } from '@jolt/react';
import { Bars as VueBars } from '@jolt/vue';
import { Bars as SvelteBars } from '@jolt/svelte';
import { barsSchema, barsMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Bars/Bars.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Bars/Bars.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Bars/Bars.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'flex h-32 w-full items-center justify-center rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Bars — Jolt UI"
  description="Equalizer-style bars — a CSS-only loader for React, Vue, and Svelte."
>
  <Breadcrumbs id="bars" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Bars</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    Five equalizer bars pulsing in sequence, pure CSS — one design language, three frameworks. It
    exposes <code class={codePill}>role="status"</code> with an accessible label, and pauses under reduced-motion.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="bars">
      <div class={previewBox} slot="react"><ReactBars /></div>
      <div class={previewBox} slot="vue"><VueBars /></div>
      <div class={previewBox} slot="svelte"><SvelteBars /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={barsMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Pure CSS; color, size &amp; speed are props.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={barsSchema} />
  <ComponentPager id="bars" />
</ComponentsLayout>
