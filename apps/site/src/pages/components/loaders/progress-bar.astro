---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { ProgressBar as ReactProgressBar } from '@jolt/react';
import { ProgressBar as VueProgressBar } from '@jolt/vue';
import { ProgressBar as SvelteProgressBar } from '@jolt/svelte';
import { progressBarSchema, progressBarMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/ProgressBar/ProgressBar.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/ProgressBar/ProgressBar.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/ProgressBar/ProgressBar.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'flex h-32 w-full items-center justify-center rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Progress Bar — Jolt UI"
  description="An indeterminate progress bar loader — CSS-only, for React, Vue, and Svelte."
>
  <Breadcrumbs id="progress-bar" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Progress Bar</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    An indeterminate fill sweeping across a track, pure CSS — one design language, three frameworks.
    It exposes <code class={codePill}>role="status"</code> with an accessible label, and pauses to a static
    partial fill under reduced-motion.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="progress-bar">
      <div class={previewBox} slot="react"><ReactProgressBar /></div>
      <div class={previewBox} slot="vue"><VueProgressBar /></div>
      <div class={previewBox} slot="svelte"><SvelteProgressBar /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={progressBarMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Pure CSS; color, width, thickness &amp; speed are props.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={progressBarSchema} />
  <ComponentPager id="progress-bar" />
</ComponentsLayout>
