---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { DotBounce as ReactDotBounce } from '@jolt/react';
import { DotBounce as VueDotBounce } from '@jolt/vue';
import { DotBounce as SvelteDotBounce } from '@jolt/svelte';
import { dotBounceSchema, dotBounceMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/DotBounce/DotBounce.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/DotBounce/DotBounce.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/DotBounce/DotBounce.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'flex h-32 w-full items-center justify-center rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Dot Bounce — Jolt UI"
  description="Three bouncing dots — a CSS-only loader for React, Vue, and Svelte."
>
  <Breadcrumbs id="dot-bounce" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Dot Bounce</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    Three dots bouncing in sequence, pure CSS — one design language, three frameworks. It exposes <code
      class={codePill}>role="status"</code
    > with an accessible label, and pauses under reduced-motion.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="dot-bounce">
      <div class={previewBox} slot="react"><ReactDotBounce /></div>
      <div class={previewBox} slot="vue"><VueDotBounce /></div>
      <div class={previewBox} slot="svelte"><SvelteDotBounce /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={dotBounceMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Pure CSS; color, size &amp; speed are props.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={dotBounceSchema} />
  <ComponentPager id="dot-bounce" />
</ComponentsLayout>
