---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Tactile as ReactTactile } from '@jolt/react';
import { Tactile as VueTactile } from '@jolt/vue';
import { Tactile as SvelteTactile } from '@jolt/svelte';
import { tactileSchema, tactileMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Tactile/Tactile.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Tactile/Tactile.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Tactile/Tactile.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'flex h-32 w-full items-center justify-center rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Tactile Button — Jolt UI"
  description="A raised button that presses down on click — CSS-only, for React, Vue, and Svelte."
>
  <Breadcrumbs id="tactile" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Tactile</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A real <code class={codePill}>&lt;button&gt;</code> — a raised button that presses down with a collapsing
    shadow when you click it — pure CSS, one design language, three frameworks. The label is the button's
    text (children/slot, or the <code class={codePill}>label</code> prop); click and
    <code class={codePill}>disabled</code> are forwarded. Under reduced-motion the press is instant.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="tactile">
      <div class={previewBox} slot="react"><ReactTactile label="Get started" /></div>
      <div class={previewBox} slot="vue"><VueTactile label="Get started" /></div>
      <div class={previewBox} slot="svelte"><SvelteTactile label="Get started" /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={tactileMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Pure CSS; renders a native <code class={codePill}>&lt;button&gt;</code> and forwards click / disabled
      / other native attributes.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={tactileSchema} />
  <ComponentPager id="tactile" />
</ComponentsLayout>
