---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Glow as ReactGlow } from '@jolt/react';
import { Glow as VueGlow } from '@jolt/vue';
import { Glow as SvelteGlow } from '@jolt/svelte';
import { glowSchema, glowMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Glow/Glow.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Glow/Glow.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Glow/Glow.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'flex h-32 w-full items-center justify-center rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Glow Button — Jolt UI"
  description="A glowing call-to-action button — CSS-only, for React, Vue, and Svelte."
>
  <Breadcrumbs id="glow" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Glow</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A real <code class={codePill}>&lt;button&gt;</code> with a breathing halo that pulses in and out —
    pure CSS, one design language, three frameworks. The label is the button's text (children/slot, or
    the <code class={codePill}>label</code> prop); click and <code class={codePill}>disabled</code> are
    forwarded. Under reduced-motion the pulse settles to a steady glow.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="glow">
      <div class={previewBox} slot="react"><ReactGlow label="Get started" /></div>
      <div class={previewBox} slot="vue"><VueGlow label="Get started" /></div>
      <div class={previewBox} slot="svelte"><SvelteGlow label="Get started" /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={glowMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Pure CSS; renders a native <code class={codePill}>&lt;button&gt;</code> and forwards click / disabled
      / other native attributes.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={glowSchema} />
  <ComponentPager id="glow" />
</ComponentsLayout>
