---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { BorderDraw as ReactBorderDraw } from '@jolt/react';
import { BorderDraw as VueBorderDraw } from '@jolt/vue';
import { BorderDraw as SvelteBorderDraw } from '@jolt/svelte';
import { borderDrawSchema, borderDrawMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/BorderDraw/BorderDraw.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/BorderDraw/BorderDraw.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/BorderDraw/BorderDraw.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'flex h-32 w-full items-center justify-center rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Border Draw Button — Jolt UI"
  description="A ghost button with a flowing gradient border — CSS-only, for React, Vue, and Svelte."
>
  <Breadcrumbs id="border-draw" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Border Draw</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A real <code class={codePill}>&lt;button&gt;</code> with a gradient border that flows continuously
    around the perimeter — pure CSS, one design language, three frameworks. The label is the button's
    text (children/slot, or the <code class={codePill}>label</code> prop); click and
    <code class={codePill}>disabled</code> are forwarded. Under reduced-motion the border flow freezes.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="border-draw">
      <div class={previewBox} slot="react"><ReactBorderDraw label="Get started" /></div>
      <div class={previewBox} slot="vue"><VueBorderDraw label="Get started" /></div>
      <div class={previewBox} slot="svelte"><SvelteBorderDraw label="Get started" /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={borderDrawMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Pure CSS; renders a native <code class={codePill}>&lt;button&gt;</code> and forwards click / disabled
      / other native attributes.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={borderDrawSchema} />
  <ComponentPager id="border-draw" />
</ComponentsLayout>
