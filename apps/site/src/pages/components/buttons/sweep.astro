---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Sweep as ReactSweep } from '@jolt/react';
import { Sweep as VueSweep } from '@jolt/vue';
import { Sweep as SvelteSweep } from '@jolt/svelte';
import { sweepSchema, sweepMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Sweep/Sweep.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Sweep/Sweep.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Sweep/Sweep.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'flex h-32 w-full items-center justify-center rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Sweep Button — Jolt UI"
  description="A ghost button whose fill wipes in on hover — CSS-only, for React, Vue, and Svelte."
>
  <Breadcrumbs id="sweep" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Sweep</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A real <code class={codePill}>&lt;button&gt;</code> — a ghost button whose colored fill wipes in from
    the left on hover or keyboard focus — pure CSS, one design language, three frameworks. The label is
    the button's text (children/slot, or the <code class={codePill}>label</code> prop); click and
    <code class={codePill}>disabled</code> are forwarded. Under reduced-motion the fill is instant.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="sweep">
      <div class={previewBox} slot="react"><ReactSweep label="Get started" /></div>
      <div class={previewBox} slot="vue"><VueSweep label="Get started" /></div>
      <div class={previewBox} slot="svelte"><SvelteSweep label="Get started" /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={sweepMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Pure CSS; renders a native <code class={codePill}>&lt;button&gt;</code> and forwards click / disabled
      / other native attributes.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={sweepSchema} />
  <ComponentPager id="sweep" />
</ComponentsLayout>
