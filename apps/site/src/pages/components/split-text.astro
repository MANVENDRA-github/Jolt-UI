---
import Base from '../../layouts/Base.astro';
import CodeTabs from '../../components/CodeTabs.astro';
import { SplitText as ReactSplitText } from '@jolt/react';
import { SplitText as VueSplitText } from '@jolt/vue';
import { SplitText as SvelteSplitText } from '@jolt/svelte';
import { splitTextPropsTable } from '@jolt/core';
import reactSource from '../../../../../packages/react/src/components/SplitText/SplitText.tsx?raw';
import vueSource from '../../../../../packages/vue/src/components/SplitText/SplitText.vue?raw';
import svelteSource from '../../../../../packages/svelte/src/components/SplitText/SplitText.svelte?raw';

const props = splitTextPropsTable();
const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const installTabs = [
  { label: 'jsrepo', lang: 'bash', code: 'npx jsrepo add <registry-url>/r/react/split-text' },
  { label: 'peer deps', lang: 'bash', code: 'pnpm add gsap zod' },
];
---

<Base title="SplitText — Jolt UI">
  <h1 class="text-3xl font-bold">SplitText</h1>
  <p class="mt-2 opacity-80">A staggered character/word reveal — one design language, three frameworks.</p>

  <section class="mt-10 space-y-8">
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">React</h2>
      <div class="mt-1 text-3xl font-semibold">
        <ReactSplitText text="Animated with React" client:visible />
      </div>
    </div>
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">Vue</h2>
      <div class="mt-1 text-3xl font-semibold">
        <VueSplitText text="Animated with Vue" client:visible />
      </div>
    </div>
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">Svelte</h2>
      <div class="mt-1 text-3xl font-semibold">
        <SvelteSplitText text="Animated with Svelte" client:visible />
      </div>
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Installation</h2>
    <p class="mt-2 text-sm opacity-70">
      Adds the component plus its bundled core. Swap <code>react</code> for <code>vue</code> or
      <code>svelte</code>.
    </p>
    <div class="mt-3"><CodeTabs tabs={installTabs} /></div>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm opacity-70">Identical behavior, idiomatic per framework.</p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Props</h2>
    <table class="mt-3 w-full border-collapse text-left text-sm">
      <thead>
        <tr class="border-b border-white/15">
          <th class="py-2 pr-4 font-semibold">Prop</th>
          <th class="py-2 pr-4 font-semibold">Type</th>
          <th class="py-2 pr-4 font-semibold">Default</th>
          <th class="py-2 font-semibold">Description</th>
        </tr>
      </thead>
      <tbody>
        {
          props.map((p) => (
            <tr class="border-b border-white/10">
              <td class="py-2 pr-4 font-mono">{p.name}</td>
              <td class="py-2 pr-4 font-mono opacity-80">{p.type}</td>
              <td class="py-2 pr-4 font-mono opacity-80">{p.default ?? 'required'}</td>
              <td class="py-2 opacity-80">{p.description}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>
</Base>
