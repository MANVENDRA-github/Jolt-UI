---
import Base from '../../layouts/Base.astro';
import CodeTabs from '../../components/CodeTabs.astro';
import InstallBlock from '../../components/InstallBlock.astro';
import { ScrollVelocity as ReactScrollVelocity } from '@jolt/react';
import { ScrollVelocity as VueScrollVelocity } from '@jolt/vue';
import { ScrollVelocity as SvelteScrollVelocity } from '@jolt/svelte';
import { propsTable, scrollVelocitySchema, scrollVelocityMeta } from '@jolt/core';
import reactSource from '../../../../../packages/react/src/components/ScrollVelocity/ScrollVelocity.tsx?raw';
import vueSource from '../../../../../packages/vue/src/components/ScrollVelocity/ScrollVelocity.vue?raw';
import svelteSource from '../../../../../packages/svelte/src/components/ScrollVelocity/ScrollVelocity.svelte?raw';

const props = propsTable(scrollVelocitySchema);
const marquee = 'Animated components for React · Vue · Svelte ·';
const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
---

<Base title="ScrollVelocity — Jolt UI">
  <h1 class="text-3xl font-bold">ScrollVelocity</h1>
  <p class="mt-2 opacity-80">
    A marquee whose speed and direction react to scroll velocity — GSAP, three frameworks. <span
      class="opacity-70">(Scroll the page to feel it.)</span>
  </p>

  <section class="mt-10 space-y-8">
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">React</h2>
      <div class="mt-1 text-4xl font-bold">
        <ReactScrollVelocity text={marquee} client:visible />
      </div>
    </div>
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">Vue</h2>
      <div class="mt-1 text-4xl font-bold"><VueScrollVelocity text={marquee} client:visible /></div>
    </div>
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">Svelte</h2>
      <div class="mt-1 text-4xl font-bold">
        <SvelteScrollVelocity text={marquee} client:visible />
      </div>
    </div>
  </section>

  <InstallBlock meta={scrollVelocityMeta} />

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm opacity-70">Identical behavior, idiomatic per framework.</p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Props</h2>
    <table class="mt-3 w-full border-collapse text-left text-sm">
      <thead>
        <tr class="border-b border-white/15">
          <th class="py-2 pr-4 font-semibold">Prop</th>
          <th class="py-2 pr-4 font-semibold">Type</th>
          <th class="py-2 pr-4 font-semibold">Default</th>
          <th class="py-2 font-semibold">Description</th>
        </tr>
      </thead>
      <tbody>
        {
          props.map((p) => (
            <tr class="border-b border-white/10">
              <td class="py-2 pr-4 font-mono">{p.name}</td>
              <td class="py-2 pr-4 font-mono opacity-80">{p.type}</td>
              <td class="py-2 pr-4 font-mono opacity-80">{p.default ?? 'required'}</td>
              <td class="py-2 opacity-80">{p.description}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>
</Base>
