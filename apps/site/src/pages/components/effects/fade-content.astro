---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { FadeContent as ReactFadeContent } from '@jolt/react';
import { FadeContent as VueFadeContent } from '@jolt/vue';
import { FadeContent as SvelteFadeContent } from '@jolt/svelte';
import { fadeContentSchema, fadeContentMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/FadeContent/FadeContent.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/FadeContent/FadeContent.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/FadeContent/FadeContent.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'h-40 w-full rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)] p-3';
const cardBody = 'space-y-2';
const cardTitle = 'text-lg font-semibold';
const cardCopy = 'text-sm text-[var(--jolt-text-muted)]';
---

<ComponentsLayout title="FadeContent — Jolt UI">
  <Breadcrumbs id="fade-content" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">FadeContent</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">Fades your content in when it scrolls into view</p>

  <div class="mt-8">
    <FrameworkSwitcher id="fade-content">
      <div class={previewBox} slot="react">
        <ReactFadeContent client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Fade Content</div>
            <p class={cardCopy}>Fades your content in when it scrolls into view</p>
          </div>
        </ReactFadeContent>
      </div>
      <div class={previewBox} slot="vue">
        <VueFadeContent client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Fade Content</div>
            <p class={cardCopy}>Fades your content in when it scrolls into view</p>
          </div>
        </VueFadeContent>
      </div>
      <div class={previewBox} slot="svelte">
        <SvelteFadeContent client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Fade Content</div>
            <p class={cardCopy}>Fades your content in when it scrolls into view</p>
          </div>
        </SvelteFadeContent>
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={fadeContentMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={fadeContentSchema} />
  <ComponentPager id="fade-content" />
</ComponentsLayout>
