---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Magnet as ReactMagnet } from '@jolt/react';
import { Magnet as VueMagnet } from '@jolt/vue';
import { Magnet as SvelteMagnet } from '@jolt/svelte';
import { magnetSchema, magnetMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Magnet/Magnet.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Magnet/Magnet.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Magnet/Magnet.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'h-40 w-full rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)] p-3';
const cardBody = 'space-y-2';
const cardTitle = 'text-lg font-semibold';
const cardCopy = 'text-sm text-[var(--jolt-text-muted)]';
---

<ComponentsLayout title="Magnet — Jolt UI">
  <Breadcrumbs id="magnet" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Magnet</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">Pulls your content toward the cursor</p>

  <div class="mt-8">
    <FrameworkSwitcher id="magnet">
      <div class={previewBox} slot="react">
        <ReactMagnet client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Magnet</div>
            <p class={cardCopy}>Pulls your content toward the cursor</p>
          </div>
        </ReactMagnet>
      </div>
      <div class={previewBox} slot="vue">
        <VueMagnet client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Magnet</div>
            <p class={cardCopy}>Pulls your content toward the cursor</p>
          </div>
        </VueMagnet>
      </div>
      <div class={previewBox} slot="svelte">
        <SvelteMagnet client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Magnet</div>
            <p class={cardCopy}>Pulls your content toward the cursor</p>
          </div>
        </SvelteMagnet>
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={magnetMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={magnetSchema} />
  <ComponentPager id="magnet" />
</ComponentsLayout>
