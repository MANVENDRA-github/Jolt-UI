---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { AnimatedContent as ReactAnimatedContent } from '@jolt/react';
import { AnimatedContent as VueAnimatedContent } from '@jolt/vue';
import { AnimatedContent as SvelteAnimatedContent } from '@jolt/svelte';
import { animatedContentSchema, animatedContentMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/AnimatedContent/AnimatedContent.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/AnimatedContent/AnimatedContent.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/AnimatedContent/AnimatedContent.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'h-40 w-full rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)] p-3';
const cardBody = 'space-y-2';
const cardTitle = 'text-lg font-semibold';
const cardCopy = 'text-sm text-[var(--jolt-text-muted)]';
---

<ComponentsLayout title="AnimatedContent — Jolt UI">
  <Breadcrumbs id="animated-content" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">AnimatedContent</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    Slides and scales your content in when it scrolls into view
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="animated-content">
      <div class={previewBox} slot="react">
        <ReactAnimatedContent client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Animated Content</div>
            <p class={cardCopy}>Slides and scales your content in when it scrolls into view</p>
          </div>
        </ReactAnimatedContent>
      </div>
      <div class={previewBox} slot="vue">
        <VueAnimatedContent client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Animated Content</div>
            <p class={cardCopy}>Slides and scales your content in when it scrolls into view</p>
          </div>
        </VueAnimatedContent>
      </div>
      <div class={previewBox} slot="svelte">
        <SvelteAnimatedContent client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Animated Content</div>
            <p class={cardCopy}>Slides and scales your content in when it scrolls into view</p>
          </div>
        </SvelteAnimatedContent>
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={animatedContentMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={animatedContentSchema} />
  <ComponentPager id="animated-content" />
</ComponentsLayout>
