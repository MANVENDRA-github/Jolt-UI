---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { BorderGlow as ReactBorderGlow } from '@jolt/react';
import { BorderGlow as VueBorderGlow } from '@jolt/vue';
import { BorderGlow as SvelteBorderGlow } from '@jolt/svelte';
import { borderGlowSchema, borderGlowMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/BorderGlow/BorderGlow.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/BorderGlow/BorderGlow.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/BorderGlow/BorderGlow.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'h-40 w-full rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)] p-3';
const cardBody = 'space-y-2';
const cardTitle = 'text-lg font-semibold';
const cardCopy = 'text-sm text-[var(--jolt-text-muted)]';
---

<ComponentsLayout title="BorderGlow — Jolt UI">
  <Breadcrumbs id="border-glow" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">BorderGlow</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">The border lights up where the cursor is</p>

  <div class="mt-8">
    <FrameworkSwitcher id="border-glow">
      <div class={previewBox} slot="react">
        <ReactBorderGlow client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Border Glow</div>
            <p class={cardCopy}>The border lights up where the cursor is</p>
          </div>
        </ReactBorderGlow>
      </div>
      <div class={previewBox} slot="vue">
        <VueBorderGlow client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Border Glow</div>
            <p class={cardCopy}>The border lights up where the cursor is</p>
          </div>
        </VueBorderGlow>
      </div>
      <div class={previewBox} slot="svelte">
        <SvelteBorderGlow client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Border Glow</div>
            <p class={cardCopy}>The border lights up where the cursor is</p>
          </div>
        </SvelteBorderGlow>
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={borderGlowMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={borderGlowSchema} />
  <ComponentPager id="border-glow" />
</ComponentsLayout>
