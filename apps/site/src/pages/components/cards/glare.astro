---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Glare as ReactGlare } from '@jolt/react';
import { Glare as VueGlare } from '@jolt/vue';
import { Glare as SvelteGlare } from '@jolt/svelte';
import { glareSchema, glareMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Glare/Glare.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Glare/Glare.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Glare/Glare.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'h-40 w-full rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)] p-3';
const cardBody = 'space-y-2';
const cardTitle = 'text-lg font-semibold';
const cardCopy = 'text-sm text-[var(--jolt-text-muted)]';
---

<ComponentsLayout title="Glare — Jolt UI">
  <Breadcrumbs id="glare" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Glare</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A glossy sheen that follows the cursor across the card
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="glare">
      <div class={previewBox} slot="react">
        <ReactGlare client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Glare</div>
            <p class={cardCopy}>A glossy sheen that follows the cursor across the card</p>
          </div>
        </ReactGlare>
      </div>
      <div class={previewBox} slot="vue">
        <VueGlare client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Glare</div>
            <p class={cardCopy}>A glossy sheen that follows the cursor across the card</p>
          </div>
        </VueGlare>
      </div>
      <div class={previewBox} slot="svelte">
        <SvelteGlare client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Glare</div>
            <p class={cardCopy}>A glossy sheen that follows the cursor across the card</p>
          </div>
        </SvelteGlare>
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={glareMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={glareSchema} />
  <ComponentPager id="glare" />
</ComponentsLayout>
