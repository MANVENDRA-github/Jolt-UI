---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Tilt as ReactTilt } from '@jolt/react';
import { Tilt as VueTilt } from '@jolt/vue';
import { Tilt as SvelteTilt } from '@jolt/svelte';
import { tiltSchema, tiltMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Tilt/Tilt.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Tilt/Tilt.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Tilt/Tilt.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'h-40 w-full rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)] p-3';
const cardBody = 'space-y-2';
const cardTitle = 'text-lg font-semibold';
const cardText = 'text-sm text-[var(--jolt-text-muted)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Tilt Card — Jolt UI"
  description="A card that rotates in 3-D toward the cursor — CSS + a tiny pointer behavior, for React, Vue, and Svelte."
>
  <Breadcrumbs id="tilt" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Tilt</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A presentational <code class={codePill}>&lt;div&gt;</code> card that wraps your content and rotates
    in 3-D toward the cursor. One design language, three frameworks. The tilt is decorative — under reduced-motion
    the card stays flat and the pointer isn't tracked.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="tilt">
      <div class={previewBox} slot="react">
        <ReactTilt client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Tilt</div>
            <p class={cardText}>Move your cursor over this card to tilt it toward you.</p>
          </div>
        </ReactTilt>
      </div>
      <div class={previewBox} slot="vue">
        <VueTilt client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Tilt</div>
            <p class={cardText}>Move your cursor over this card to tilt it toward you.</p>
          </div>
        </VueTilt>
      </div>
      <div class={previewBox} slot="svelte">
        <SvelteTilt client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Tilt</div>
            <p class={cardText}>Move your cursor over this card to tilt it toward you.</p>
          </div>
        </SvelteTilt>
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={tiltMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      A <code class={codePill}>&lt;div&gt;</code> container; the shared pointer behavior writes the rotation
      to CSS custom properties.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={tiltSchema} />
  <ComponentPager id="tilt" />
</ComponentsLayout>
