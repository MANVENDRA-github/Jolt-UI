---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { ShineBorder as ReactShineBorder } from '@jolt/react';
import { ShineBorder as VueShineBorder } from '@jolt/vue';
import { ShineBorder as SvelteShineBorder } from '@jolt/svelte';
import { shineBorderSchema, shineBorderMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/ShineBorder/ShineBorder.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/ShineBorder/ShineBorder.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/ShineBorder/ShineBorder.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'h-40 w-full rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)] p-3';
const cardBody = 'space-y-2';
const cardTitle = 'text-lg font-semibold';
const cardText = 'text-sm text-[var(--jolt-text-muted)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Shine Border Card — Jolt UI"
  description="A card with a gradient border that continuously flows around the perimeter — CSS-only, for React, Vue, and Svelte."
>
  <Breadcrumbs id="shine-border" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Shine Border</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A presentational <code class={codePill}>&lt;div&gt;</code> card that wraps your content with a gradient
    border continuously flowing around its perimeter — pure CSS, one design language, three frameworks.
    The flow freezes to a static gradient under reduced-motion.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="shine-border">
      <div class={previewBox} slot="react">
        <ReactShineBorder>
          <div class={cardBody}>
            <div class={cardTitle}>Shine Border</div>
            <p class={cardText}>A flowing gradient frame around any content.</p>
          </div>
        </ReactShineBorder>
      </div>
      <div class={previewBox} slot="vue">
        <VueShineBorder>
          <div class={cardBody}>
            <div class={cardTitle}>Shine Border</div>
            <p class={cardText}>A flowing gradient frame around any content.</p>
          </div>
        </VueShineBorder>
      </div>
      <div class={previewBox} slot="svelte">
        <SvelteShineBorder>
          <div class={cardBody}>
            <div class={cardTitle}>Shine Border</div>
            <p class={cardText}>A flowing gradient frame around any content.</p>
          </div>
        </SvelteShineBorder>
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={shineBorderMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Pure CSS; a <code class={codePill}>&lt;div&gt;</code> container with a masked, flowing gradient
      border.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={shineBorderSchema} />
  <ComponentPager id="shine-border" />
</ComponentsLayout>
