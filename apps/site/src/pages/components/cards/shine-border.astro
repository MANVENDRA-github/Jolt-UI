---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import { ShineBorder as ReactShineBorder } from '@jolt/react';
import { ShineBorder as VueShineBorder } from '@jolt/vue';
import { ShineBorder as SvelteShineBorder } from '@jolt/svelte';
import { propsTable, shineBorderSchema, shineBorderMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/ShineBorder/ShineBorder.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/ShineBorder/ShineBorder.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/ShineBorder/ShineBorder.svelte?raw';

const props = propsTable(shineBorderSchema);
const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox = 'h-40 w-full rounded-lg border border-white/10 bg-black/20 p-3';
const cardBody = 'space-y-2';
const cardTitle = 'text-lg font-semibold';
const cardText = 'text-sm opacity-70';
---

<ComponentsLayout
  title="Shine Border Card — Jolt UI"
  description="A card with a gradient border that continuously flows around the perimeter — CSS-only, for React, Vue, and Svelte."
>
  <h1 class="text-3xl font-bold">Shine Border</h1>
  <p class="mt-2 opacity-80">
    A presentational <code class="rounded bg-white/10 px-1">&lt;div&gt;</code> card that wraps your content
    with a gradient border continuously flowing around its perimeter — pure CSS, one design language,
    three frameworks. The flow freezes to a static gradient under reduced-motion.
  </p>

  <section class="mt-10 space-y-8">
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">React</h2>
      <div class={previewBox}>
        <ReactShineBorder>
          <div class={cardBody}>
            <div class={cardTitle}>Shine Border</div>
            <p class={cardText}>A flowing gradient frame around any content.</p>
          </div>
        </ReactShineBorder>
      </div>
    </div>
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">Vue</h2>
      <div class={previewBox}>
        <VueShineBorder>
          <div class={cardBody}>
            <div class={cardTitle}>Shine Border</div>
            <p class={cardText}>A flowing gradient frame around any content.</p>
          </div>
        </VueShineBorder>
      </div>
    </div>
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">Svelte</h2>
      <div class={previewBox}>
        <SvelteShineBorder>
          <div class={cardBody}>
            <div class={cardTitle}>Shine Border</div>
            <p class={cardText}>A flowing gradient frame around any content.</p>
          </div>
        </SvelteShineBorder>
      </div>
    </div>
  </section>

  <InstallBlock meta={shineBorderMeta} />

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm opacity-70">
      Pure CSS; a <code class="rounded bg-white/10 px-1">&lt;div&gt;</code> container with a masked, flowing
      gradient border.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Props</h2>
    <table class="mt-3 w-full border-collapse text-left text-sm">
      <thead>
        <tr class="border-b border-white/15">
          <th class="py-2 pr-4 font-semibold">Prop</th>
          <th class="py-2 pr-4 font-semibold">Type</th>
          <th class="py-2 pr-4 font-semibold">Default</th>
          <th class="py-2 font-semibold">Description</th>
        </tr>
      </thead>
      <tbody>
        {
          props.map((p) => (
            <tr class="border-b border-white/10">
              <td class="py-2 pr-4 font-mono">{p.name}</td>
              <td class="py-2 pr-4 font-mono opacity-80">{p.type}</td>
              <td class="py-2 pr-4 font-mono opacity-80">{p.default ?? 'required'}</td>
              <td class="py-2 opacity-80">{p.description}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>
</ComponentsLayout>
