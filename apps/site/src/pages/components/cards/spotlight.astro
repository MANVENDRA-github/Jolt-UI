---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Spotlight as ReactSpotlight } from '@jolt/react';
import { Spotlight as VueSpotlight } from '@jolt/vue';
import { Spotlight as SvelteSpotlight } from '@jolt/svelte';
import { spotlightSchema, spotlightMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Spotlight/Spotlight.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Spotlight/Spotlight.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Spotlight/Spotlight.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'h-40 w-full rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)] p-3';
const cardBody = 'space-y-2';
const cardTitle = 'text-lg font-semibold';
const cardText = 'text-sm text-[var(--jolt-text-muted)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Spotlight Card — Jolt UI"
  description="A card whose radial glow follows the cursor — CSS + a tiny pointer behavior, for React, Vue, and Svelte."
>
  <Breadcrumbs id="spotlight" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Spotlight</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A presentational <code class={codePill}>&lt;div&gt;</code> card that wraps your content; a soft radial
    glow follows the cursor across its surface. One design language, three frameworks. The glow is decorative
    — under reduced-motion it stays centered and the pointer isn't tracked.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="spotlight">
      <div class={previewBox} slot="react">
        <ReactSpotlight client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Spotlight</div>
            <p class={cardText}>Move your cursor across this card to see the glow follow.</p>
          </div>
        </ReactSpotlight>
      </div>
      <div class={previewBox} slot="vue">
        <VueSpotlight client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Spotlight</div>
            <p class={cardText}>Move your cursor across this card to see the glow follow.</p>
          </div>
        </VueSpotlight>
      </div>
      <div class={previewBox} slot="svelte">
        <SvelteSpotlight client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Spotlight</div>
            <p class={cardText}>Move your cursor across this card to see the glow follow.</p>
          </div>
        </SvelteSpotlight>
      </div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={spotlightMeta} />

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      A <code class={codePill}>&lt;div&gt;</code> container; the shared pointer behavior writes the glow
      position to CSS custom properties.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={spotlightSchema} />
  <ComponentPager id="spotlight" />
</ComponentsLayout>
