---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import { Spotlight as ReactSpotlight } from '@jolt/react';
import { Spotlight as VueSpotlight } from '@jolt/vue';
import { Spotlight as SvelteSpotlight } from '@jolt/svelte';
import { propsTable, spotlightSchema, spotlightMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Spotlight/Spotlight.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Spotlight/Spotlight.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Spotlight/Spotlight.svelte?raw';

const props = propsTable(spotlightSchema);
const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox = 'h-40 w-full rounded-lg border border-white/10 bg-black/20 p-3';
const cardBody = 'space-y-2';
const cardTitle = 'text-lg font-semibold';
const cardText = 'text-sm opacity-70';
---

<ComponentsLayout
  title="Spotlight Card — Jolt UI"
  description="A card whose radial glow follows the cursor — CSS + a tiny pointer behavior, for React, Vue, and Svelte."
>
  <h1 class="text-3xl font-bold">Spotlight</h1>
  <p class="mt-2 opacity-80">
    A presentational <code class="rounded bg-white/10 px-1">&lt;div&gt;</code> card that wraps your content;
    a soft radial glow follows the cursor across its surface. One design language, three frameworks. The
    glow is decorative — under reduced-motion it stays centered and the pointer isn't tracked.
  </p>

  <section class="mt-10 space-y-8">
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">React</h2>
      <div class={previewBox}>
        <ReactSpotlight client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Spotlight</div>
            <p class={cardText}>Move your cursor across this card to see the glow follow.</p>
          </div>
        </ReactSpotlight>
      </div>
    </div>
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">Vue</h2>
      <div class={previewBox}>
        <VueSpotlight client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Spotlight</div>
            <p class={cardText}>Move your cursor across this card to see the glow follow.</p>
          </div>
        </VueSpotlight>
      </div>
    </div>
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">Svelte</h2>
      <div class={previewBox}>
        <SvelteSpotlight client:visible>
          <div class={cardBody}>
            <div class={cardTitle}>Spotlight</div>
            <p class={cardText}>Move your cursor across this card to see the glow follow.</p>
          </div>
        </SvelteSpotlight>
      </div>
    </div>
  </section>

  <InstallBlock meta={spotlightMeta} />

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm opacity-70">
      A <code class="rounded bg-white/10 px-1">&lt;div&gt;</code> container; the shared pointer behavior
      writes the glow position to CSS custom properties.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Props</h2>
    <table class="mt-3 w-full border-collapse text-left text-sm">
      <thead>
        <tr class="border-b border-white/15">
          <th class="py-2 pr-4 font-semibold">Prop</th>
          <th class="py-2 pr-4 font-semibold">Type</th>
          <th class="py-2 pr-4 font-semibold">Default</th>
          <th class="py-2 font-semibold">Description</th>
        </tr>
      </thead>
      <tbody>
        {
          props.map((p) => (
            <tr class="border-b border-white/10">
              <td class="py-2 pr-4 font-mono">{p.name}</td>
              <td class="py-2 pr-4 font-mono opacity-80">{p.type}</td>
              <td class="py-2 pr-4 font-mono opacity-80">{p.default ?? 'required'}</td>
              <td class="py-2 opacity-80">{p.description}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>
</ComponentsLayout>
