---
import ComponentsLayout from '../../layouts/ComponentsLayout.astro';
import {
  SplitText,
  BlurIn,
  Wave,
  GradientText,
  ShinyText,
  Typewriter,
  RotatingWords,
  CountUp,
  Scramble,
  ScrollVelocity,
  Particles,
  Waves,
  Dots,
  Globe,
  Rings,
  Aurora,
  Spinner,
  DotBounce,
  Bars,
  Pulse,
  Ripple,
  Grid,
  ProgressBar,
  Shimmer,
  Glow,
  Gradient,
  Sweep,
  BorderDraw,
  Tactile,
  Spotlight,
  Tilt,
  ShineBorder,
  FadeUp,
  FlipIn,
  Neon,
  // gen:card-import
} from '@jolt/react';

const card =
  'group block overflow-hidden rounded-[var(--radius-jolt-lg)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-raised)] p-5 transition hover:border-[color:var(--jolt-border-strong)] hover:shadow-[var(--shadow-jolt-glow)]';
const preview = 'flex h-20 items-center overflow-hidden text-2xl font-bold';
const name = 'mt-3 text-sm font-semibold';
const blurb = 'mt-0.5 font-mono text-xs text-[var(--jolt-text-subtle)]';
// Preview wrappers shared by the non-text cards.
const bgPreview =
  'relative h-20 overflow-hidden rounded-[var(--radius-jolt-sm)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)]';
const centerPreview = 'flex h-20 items-center justify-center';
// Buttons are interactive (a real <button>), so their card is a <div> with a separate
// "View" link — a live <button> must not be nested inside the card's <a> (invalid HTML +
// a double tab stop). See DECISIONS D-036.
const buttonCard =
  'overflow-hidden rounded-[var(--radius-jolt-lg)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-raised)] p-5';
const viewLink =
  'mt-3 inline-block font-mono text-xs text-[var(--jolt-accent)] transition hover:text-[var(--jolt-accent-hover)]';
const grid = 'mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4';
---

<ComponentsLayout
  title="Components — Jolt UI"
  description="Browse Jolt UI's animated components — live React, Vue, and Svelte previews from one design language, kept identical by an automated parity gate."
  wide
>
  <h1 class="font-display text-3xl font-semibold tracking-tight">Components</h1>
  <p class="mt-2 max-w-2xl text-[var(--jolt-text-muted)]">
    Animated components for React, Vue &amp; Svelte from one design language, kept identical by an
    automated parity gate. Previews are live (React shown).
  </p>

  <section id="text" class="mt-12 scroll-mt-24">
    <h2 class="font-display text-xl font-semibold">Text Animations</h2>
    <div class={grid}>
      <a href="/components/text/split-text" class={card}>
        <div class={preview}><SplitText text="Split Text" client:visible /></div>
        <div class={name}>Split Text</div>
        <div class={blurb}>Staggered character reveal (GSAP)</div>
      </a>
      <a href="/components/text/blur-in" class={card}>
        <div class={preview}><BlurIn text="Blur In" /></div>
        <div class={name}>Blur In</div>
        <div class={blurb}>Per-character fade + de-blur</div>
      </a>
      <a href="/components/text/wave" class={card}>
        <div class={preview}><Wave text="Wave" /></div>
        <div class={name}>Wave</div>
        <div class={blurb}>Traveling per-character bob</div>
      </a>
      <a href="/components/text/gradient-text" class={card}>
        <div class={preview}><GradientText text="Gradient Text" /></div>
        <div class={name}>Gradient Text</div>
        <div class={blurb}>Flowing multi-color gradient</div>
      </a>
      <a href="/components/text/shiny-text" class={card}>
        <div class={preview}><ShinyText text="Shiny Text" /></div>
        <div class={name}>Shiny Text</div>
        <div class={blurb}>Sweeping sheen across the text</div>
      </a>
      <a href="/components/text/typewriter" class={card}>
        <div class={preview}><Typewriter text="Typewriter" /></div>
        <div class={name}>Typewriter</div>
        <div class={blurb}>Character-by-character reveal + caret</div>
      </a>
      <a href="/components/text/rotating-words" class={card}>
        <div class={preview}>Build <RotatingWords words={['fast', 'bold', 'clean']} /></div>
        <div class={name}>Rotating Words</div>
        <div class={blurb}>Vertical word cycler</div>
      </a>
      <a href="/components/text/count-up" class={card}>
        <div class={`${preview} tabular-nums`}>
          <CountUp to={12500} separator="," client:visible />
        </div>
        <div class={name}>Count Up</div>
        <div class={blurb}>Animate a number to a target (GSAP)</div>
      </a>
      <a href="/components/text/scramble" class={card}>
        <div class={preview}><Scramble text="Scramble" client:visible /></div>
        <div class={name}>Scramble</div>
        <div class={blurb}>Decode from a churn of characters (GSAP)</div>
      </a>
      <a href="/components/text/scroll-velocity" class={card}>
        <div class={preview}><ScrollVelocity text="Scroll · Velocity ·" client:visible /></div>
        <div class={name}>Scroll Velocity</div>
        <div class={blurb}>Marquee that reacts to scroll (GSAP)</div>
      </a>
      <a href="/components/text/fade-up" class={card}>
        <div class={preview}><FadeUp text="Fade Up" /></div>
        <div class={name}>Fade Up</div>
        <div class={blurb}>Per-character rise + fade-in entrance</div>
      </a>
      <a href="/components/text/flip-in" class={card}>
        <div class={preview}><FlipIn text="Flip In" /></div>
        <div class={name}>Flip In</div>
        <div class={blurb}>Per-character 3D flip-in entrance</div>
      </a>
      <a href="/components/text/neon" class={card}>
        <div class={preview}><Neon text="Neon" /></div>
        <div class={name}>Neon</div>
        <div class={blurb}>Neon sign that flickers on to a steady glow</div>
      </a>
      {/* gen:card */}
    </div>
  </section>

  <section id="backgrounds" class="mt-12 scroll-mt-24">
    <h2 class="font-display text-xl font-semibold">Backgrounds</h2>
    <div class={grid}>
      <a href="/components/backgrounds/particles" class={card}>
        <div class={bgPreview}><Particles client:visible /></div>
        <div class={name}>Particles</div>
        <div class={blurb}>Drifting WebGL point field (Three.js)</div>
      </a>
      <a href="/components/backgrounds/waves" class={card}>
        <div class={bgPreview}><Waves client:visible /></div>
        <div class={name}>Waves</div>
        <div class={blurb}>Undulating wireframe plane (Three.js)</div>
      </a>
      <a href="/components/backgrounds/dots" class={card}>
        <div class={bgPreview}><Dots client:visible /></div>
        <div class={name}>Dots</div>
        <div class={blurb}>Rippling grid of points (Three.js)</div>
      </a>
      <a href="/components/backgrounds/globe" class={card}>
        <div class={bgPreview}><Globe client:visible /></div>
        <div class={name}>Globe</div>
        <div class={blurb}>Rotating sphere of points (Three.js)</div>
      </a>
      <a href="/components/backgrounds/rings" class={card}>
        <div class={bgPreview}><Rings client:visible /></div>
        <div class={name}>Rings</div>
        <div class={blurb}>Counter-rotating point rings (Three.js)</div>
      </a>
      <a href="/components/backgrounds/aurora" class={card}>
        <div class={bgPreview}><Aurora client:visible /></div>
        <div class={name}>Aurora</div>
        <div class={blurb}>Flowing light-curtain shader (Three.js)</div>
      </a>
    </div>
  </section>

  <section id="loaders" class="mt-12 scroll-mt-24">
    <h2 class="font-display text-xl font-semibold">Loaders</h2>
    <div class={grid}>
      <a href="/components/loaders/spinner" class={card}>
        <div class={centerPreview}><Spinner /></div>
        <div class={name}>Spinner</div>
        <div class={blurb}>Rotating ring (CSS)</div>
      </a>
      <a href="/components/loaders/dot-bounce" class={card}>
        <div class={centerPreview}><DotBounce /></div>
        <div class={name}>Dot Bounce</div>
        <div class={blurb}>Three bouncing dots (CSS)</div>
      </a>
      <a href="/components/loaders/bars" class={card}>
        <div class={centerPreview}><Bars /></div>
        <div class={name}>Bars</div>
        <div class={blurb}>Equalizer bars (CSS)</div>
      </a>
      <a href="/components/loaders/pulse" class={card}>
        <div class={centerPreview}><Pulse /></div>
        <div class={name}>Pulse</div>
        <div class={blurb}>Expanding sonar-ping discs (CSS)</div>
      </a>
      <a href="/components/loaders/ripple" class={card}>
        <div class={centerPreview}><Ripple /></div>
        <div class={name}>Ripple</div>
        <div class={blurb}>Concentric expanding rings (CSS)</div>
      </a>
      <a href="/components/loaders/grid" class={card}>
        <div class={centerPreview}><Grid /></div>
        <div class={name}>Grid</div>
        <div class={blurb}>3×3 squares pulsing in a wave (CSS)</div>
      </a>
      <a href="/components/loaders/progress-bar" class={card}>
        <div class={centerPreview}><ProgressBar /></div>
        <div class={name}>Progress Bar</div>
        <div class={blurb}>Indeterminate sliding fill (CSS)</div>
      </a>
    </div>
  </section>

  <section id="buttons" class="mt-12 scroll-mt-24">
    <h2 class="font-display text-xl font-semibold">Buttons</h2>
    <p class="mt-1 font-mono text-xs text-[var(--jolt-text-subtle)]">
      Previews are live and interactive — hover, focus, or click a button; follow “View” for the
      full demo.
    </p>
    <div class={grid}>
      <div class={buttonCard}>
        <div class={centerPreview}><Shimmer label="Shimmer" /></div>
        <div class={name}>Shimmer</div>
        <div class={blurb}>Sheen sweeps across the surface (CSS)</div>
        <a href="/components/buttons/shimmer" class={viewLink}>View →</a>
      </div>
      <div class={buttonCard}>
        <div class={centerPreview}><Glow label="Glow" /></div>
        <div class={name}>Glow</div>
        <div class={blurb}>Breathing halo that pulses (CSS)</div>
        <a href="/components/buttons/glow" class={viewLink}>View →</a>
      </div>
      <div class={buttonCard}>
        <div class={centerPreview}><Gradient label="Gradient" /></div>
        <div class={name}>Gradient</div>
        <div class={blurb}>Flowing multi-color gradient (CSS)</div>
        <a href="/components/buttons/gradient" class={viewLink}>View →</a>
      </div>
      <div class={buttonCard}>
        <div class={centerPreview}><Sweep label="Sweep" /></div>
        <div class={name}>Sweep</div>
        <div class={blurb}>Fill wipes in on hover/focus (CSS)</div>
        <a href="/components/buttons/sweep" class={viewLink}>View →</a>
      </div>
      <div class={buttonCard}>
        <div class={centerPreview}><BorderDraw label="Border Draw" /></div>
        <div class={name}>Border Draw</div>
        <div class={blurb}>Flowing gradient border (CSS)</div>
        <a href="/components/buttons/border-draw" class={viewLink}>View →</a>
      </div>
      <div class={buttonCard}>
        <div class={centerPreview}><Tactile label="Tactile" /></div>
        <div class={name}>Tactile</div>
        <div class={blurb}>Presses down on click (CSS)</div>
        <a href="/components/buttons/tactile" class={viewLink}>View →</a>
      </div>
    </div>
  </section>

  <section id="cards" class="mt-12 scroll-mt-24">
    <h2 class="font-display text-xl font-semibold">Cards</h2>
    <p class="mt-1 font-mono text-xs text-[var(--jolt-text-subtle)]">
      Containers that wrap your content — move your cursor over Spotlight and Tilt for the live
      effect.
    </p>
    <div class={grid}>
      <a href="/components/cards/spotlight" class={card}>
        <Spotlight client:visible>
          <div class="text-sm font-semibold">Spotlight</div>
          <div class="text-xs text-[var(--jolt-text-subtle)]">A glow that follows the cursor</div>
        </Spotlight>
        <div class={name}>Spotlight</div>
        <div class={blurb}>Radial glow follows the cursor (CSS + pointer)</div>
      </a>
      <a href="/components/cards/tilt" class={card}>
        <Tilt client:visible>
          <div class="text-sm font-semibold">Tilt</div>
          <div class="text-xs text-[var(--jolt-text-subtle)]">Rotates toward the cursor</div>
        </Tilt>
        <div class={name}>Tilt</div>
        <div class={blurb}>3-D tilt toward the cursor (CSS + pointer)</div>
      </a>
      <a href="/components/cards/shine-border" class={card}>
        <ShineBorder>
          <div class="text-sm font-semibold">Shine Border</div>
          <div class="text-xs text-[var(--jolt-text-subtle)]">A flowing gradient frame</div>
        </ShineBorder>
        <div class={name}>Shine Border</div>
        <div class={blurb}>Gradient border flows around the edge (CSS)</div>
      </a>
    </div>
  </section>
</ComponentsLayout>
