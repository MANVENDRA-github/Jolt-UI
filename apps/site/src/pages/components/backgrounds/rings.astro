---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Rings as ReactRings } from '@jolt/react';
import { Rings as VueRings } from '@jolt/vue';
import { Rings as SvelteRings } from '@jolt/svelte';
import { ringsSchema, ringsMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Rings/Rings.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Rings/Rings.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Rings/Rings.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'relative h-64 w-full overflow-hidden rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Rings — Jolt UI"
  description="Counter-rotating concentric rings of points with a radial pulse (Three.js) — a full-bleed animated background for React, Vue, and Svelte."
>
  <Breadcrumbs id="rings" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Rings</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    Concentric rings of points where alternate rings spin in opposite directions, with a gentle
    radial pulse, rendered with Three.js — one design language, three frameworks. The canvas is <code
      class={codePill}>aria-hidden</code
    > (it conveys nothing to assistive tech), and reduced-motion renders a single static frame.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="rings">
      <div class={previewBox} slot="react"><ReactRings client:visible /></div>
      <div class={previewBox} slot="vue"><VueRings client:visible /></div>
      <div class={previewBox} slot="svelte"><SvelteRings client:visible /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={ringsMeta} />
  <p class="mt-3 text-sm text-[var(--jolt-text-subtle)]">
    TypeScript consumers also need the Three.js types: <code class={codePill}
      >npm i -D @types/three</code
    >.
  </p>

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={ringsSchema} />
  <ComponentPager id="rings" />
</ComponentsLayout>
