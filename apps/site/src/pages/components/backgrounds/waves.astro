---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Waves as ReactWaves } from '@jolt/react';
import { Waves as VueWaves } from '@jolt/vue';
import { Waves as SvelteWaves } from '@jolt/svelte';
import { wavesSchema, wavesMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Waves/Waves.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Waves/Waves.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Waves/Waves.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'relative h-64 w-full overflow-hidden rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Waves — Jolt UI"
  description="A decorative undulating wireframe plane (Three.js) — a full-bleed animated background for React, Vue, and Svelte."
>
  <Breadcrumbs id="waves" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Waves</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    An undulating wireframe plane rendered with Three.js — one design language, three frameworks.
    The canvas is <code class={codePill}>aria-hidden</code> (it conveys nothing to assistive tech), and
    reduced-motion renders a single static frame.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="waves">
      <div class={previewBox} slot="react"><ReactWaves client:visible /></div>
      <div class={previewBox} slot="vue"><VueWaves client:visible /></div>
      <div class={previewBox} slot="svelte"><SvelteWaves client:visible /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={wavesMeta} />
  <p class="mt-3 text-sm text-[var(--jolt-text-subtle)]">
    TypeScript consumers also need the Three.js types: <code class={codePill}
      >npm i -D @types/three</code
    >.
  </p>

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={wavesSchema} />
  <ComponentPager id="waves" />
</ComponentsLayout>
