---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import { Waves as ReactWaves } from '@jolt/react';
import { Waves as VueWaves } from '@jolt/vue';
import { Waves as SvelteWaves } from '@jolt/svelte';
import { propsTable, wavesSchema, wavesMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Waves/Waves.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Waves/Waves.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Waves/Waves.svelte?raw';

const props = propsTable(wavesSchema);
const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'relative h-64 w-full overflow-hidden rounded-lg border border-white/10 bg-black/20';
---

<ComponentsLayout
  title="Waves — Jolt UI"
  description="A decorative undulating wireframe plane (Three.js) — a full-bleed animated background for React, Vue, and Svelte."
>
  <h1 class="text-3xl font-bold">Waves</h1>
  <p class="mt-2 opacity-80">
    An undulating wireframe plane rendered with Three.js — one design language, three frameworks.
    The canvas is <code class="rounded bg-white/10 px-1">aria-hidden</code> (it conveys nothing to assistive
    tech), and reduced-motion renders a single static frame.
  </p>

  <section class="mt-10 space-y-8">
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">React</h2>
      <div class={previewBox}><ReactWaves client:visible /></div>
    </div>
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">Vue</h2>
      <div class={previewBox}><VueWaves client:visible /></div>
    </div>
    <div>
      <h2 class="text-xs uppercase tracking-widest opacity-50">Svelte</h2>
      <div class={previewBox}><SvelteWaves client:visible /></div>
    </div>
  </section>

  <InstallBlock meta={wavesMeta} />
  <p class="mt-3 text-sm opacity-70">
    TypeScript consumers also need the Three.js types: <code class="rounded bg-white/10 px-1"
      >npm i -D @types/three</code
    >.
  </p>

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm opacity-70">Identical behavior, idiomatic per framework.</p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Props</h2>
    <table class="mt-3 w-full border-collapse text-left text-sm">
      <thead>
        <tr class="border-b border-white/15">
          <th class="py-2 pr-4 font-semibold">Prop</th>
          <th class="py-2 pr-4 font-semibold">Type</th>
          <th class="py-2 pr-4 font-semibold">Default</th>
          <th class="py-2 font-semibold">Description</th>
        </tr>
      </thead>
      <tbody>
        {
          props.map((p) => (
            <tr class="border-b border-white/10">
              <td class="py-2 pr-4 font-mono">{p.name}</td>
              <td class="py-2 pr-4 font-mono opacity-80">{p.type}</td>
              <td class="py-2 pr-4 font-mono opacity-80">{p.default ?? 'required'}</td>
              <td class="py-2 opacity-80">{p.description}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>
</ComponentsLayout>
