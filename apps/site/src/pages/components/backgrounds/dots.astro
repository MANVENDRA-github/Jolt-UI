---
import ComponentsLayout from '../../../layouts/ComponentsLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FrameworkSwitcher from '../../../components/FrameworkSwitcher.astro';
import CodeTabs from '../../../components/CodeTabs.astro';
import InstallBlock from '../../../components/InstallBlock.astro';
import PropsTable from '../../../components/PropsTable.astro';
import ComponentPager from '../../../components/ComponentPager.astro';
import { Dots as ReactDots } from '@jolt/react';
import { Dots as VueDots } from '@jolt/vue';
import { Dots as SvelteDots } from '@jolt/svelte';
import { dotsSchema, dotsMeta } from '@jolt/core';
import reactSource from '../../../../../../packages/react/src/components/Dots/Dots.tsx?raw';
import vueSource from '../../../../../../packages/vue/src/components/Dots/Dots.vue?raw';
import svelteSource from '../../../../../../packages/svelte/src/components/Dots/Dots.svelte?raw';

const sourceTabs = [
  { label: 'React', lang: 'tsx', code: reactSource },
  { label: 'Vue', lang: 'vue', code: vueSource },
  { label: 'Svelte', lang: 'svelte', code: svelteSource },
];
const previewBox =
  'relative h-64 w-full overflow-hidden rounded-[var(--radius-jolt)] border border-[color:var(--jolt-border)] bg-[var(--jolt-surface-sunken)]';
const codePill = 'rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono';
---

<ComponentsLayout
  title="Dots — Jolt UI"
  description="A decorative grid of points rippling from the center (Three.js) — a full-bleed animated background for React, Vue, and Svelte."
>
  <Breadcrumbs id="dots" />
  <h1 class="font-display text-3xl font-semibold tracking-tight">Dots</h1>
  <p class="mt-2 text-[var(--jolt-text-muted)]">
    A grid of points rippling outward from the center, rendered with Three.js — one design language,
    three frameworks. The canvas is <code class={codePill}>aria-hidden</code> (it conveys nothing to assistive
    tech), and reduced-motion renders a single static frame.
  </p>

  <div class="mt-8">
    <FrameworkSwitcher id="dots">
      <div class={previewBox} slot="react"><ReactDots client:visible /></div>
      <div class={previewBox} slot="vue"><VueDots client:visible /></div>
      <div class={previewBox} slot="svelte"><SvelteDots client:visible /></div>
    </FrameworkSwitcher>
  </div>

  <InstallBlock meta={dotsMeta} />
  <p class="mt-3 text-sm text-[var(--jolt-text-subtle)]">
    TypeScript consumers also need the Three.js types: <code class={codePill}
      >npm i -D @types/three</code
    >.
  </p>

  <section class="mt-12">
    <h2 class="font-display text-xl font-semibold">Source</h2>
    <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
      Identical behavior, idiomatic per framework.
    </p>
    <div class="mt-3"><CodeTabs tabs={sourceTabs} /></div>
  </section>

  <PropsTable schema={dotsSchema} />
  <ComponentPager id="dots" />
</ComponentsLayout>
