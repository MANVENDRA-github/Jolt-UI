---
import Base from '../layouts/Base.astro';
import { GradientText } from '@jolt/react';
---

<Base title="Jolt UI — multi-framework animated components">
  <h1 class="text-5xl font-bold"><GradientText text="Jolt UI" /></h1>
  <p class="mt-4 max-w-prose opacity-80">
    Polished animated text components for <strong>React</strong>, <strong>Vue</strong> and
    <strong>Svelte</strong> — one design language, kept identical across frameworks by a shared animation
    core and an automated parity gate. Copy-paste or <code>npx jsrepo add</code>.
  </p>
  <a
    href="/components"
    class="mt-8 inline-block rounded-lg border border-white/20 px-4 py-2 text-sm font-semibold transition hover:border-white/40"
  >
    Browse components →
  </a>
</Base>
