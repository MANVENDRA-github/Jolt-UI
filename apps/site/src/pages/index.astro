---
import Base from '../layouts/Base.astro';
import SceneStage from '../components/landing/SceneStage.astro';
import Hero from '../components/landing/Hero.astro';
import SplitStory from '../components/landing/SplitStory.astro';
import BuiltWithItself from '../components/landing/BuiltWithItself.astro';
import InstallMoment from '../components/landing/InstallMoment.astro';
import ParitySignature from '../components/landing/ParitySignature.astro';
import FinalCta from '../components/landing/FinalCta.astro';
---

<Base title="Jolt UI — multi-framework animated components" width="full">
  {
    /* The scene track: hero + split story share one sticky scene layer behind them.
      Scoped dark — the scene canvas is always abyss, whatever the site theme. */
  }
  <div class="scene-track" data-theme="dark">
    <SceneStage />
    <Hero />
    <SplitStory />
  </div>
  <BuiltWithItself />
  <InstallMoment />
  <ParitySignature />
  <FinalCta />
</Base>

<style>
  .scene-track {
    position: relative;
    background: var(--jolt-abyss);
    color: var(--jolt-text);
    overflow: clip;
  }
</style>
