---
interface Props {
  /** Tailwind max-width class, shared with the content column so the footer aligns with it. */
  maxW?: string;
}
const { maxW = 'max-w-[84rem]' } = Astro.props;
const repo = 'https://github.com/MANVENDRA-github/Jolt-UI';
---

<footer data-pagefind-ignore class="mt-20 border-t border-[color:var(--jolt-border)]">
  <div
    class:list={[
      'mx-auto flex flex-wrap items-center justify-between gap-3 px-4 py-8 text-sm text-[var(--jolt-text-subtle)] sm:px-6 lg:px-8',
      maxW,
    ]}
  >
    <span class="flex items-center gap-2">
      <svg
        class="h-3.5 w-3.5 text-[var(--jolt-accent)]"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M13 2 4 13.5h6L9 22l9-11.5h-6L13 2Z"></path>
      </svg>
      Jolt UI — React · Vue · Svelte from one design language.
    </span>
    <div class="flex gap-5">
      <a class="transition-colors hover:text-[var(--jolt-text)]" href="/components">Components</a>
      <a class="transition-colors hover:text-[var(--jolt-text)]" href="/docs/getting-started"
        >Docs</a
      >
      <a class="transition-colors hover:text-[var(--jolt-text)]" href={repo}>GitHub</a>
    </div>
  </div>
</footer>
