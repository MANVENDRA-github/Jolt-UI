---
const repo = 'https://github.com/MANVENDRA-github/Jolt-UI';
---

<footer data-pagefind-ignore class="mt-16 border-t border-white/10">
  <div
    class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-3 px-6 py-6 text-sm opacity-60"
  >
    <span>Jolt UI — React · Vue · Svelte from one design language.</span>
    <div class="flex gap-4">
      <a class="transition hover:opacity-100" href="/components">Components</a>
      <a class="transition hover:opacity-100" href="/docs/getting-started">Docs</a>
      <a class="transition hover:opacity-100" href={repo}>GitHub</a>
    </div>
  </div>
</footer>
