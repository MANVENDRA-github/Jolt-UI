---
import { propsTable } from '@jolt/core';

interface Props {
  /** The component's Zod schema; rows are derived via `propsTable`. */
  schema: Parameters<typeof propsTable>[0];
}
const { schema } = Astro.props;
const rows = propsTable(schema);
---

<section class="mt-12">
  <h2 class="font-display text-xl font-semibold">Props</h2>
  <table class="mt-3 w-full border-collapse text-left text-sm">
    <thead>
      <tr class="border-b border-[color:var(--jolt-border-strong)]">
        <th class="py-2 pr-4 font-semibold">Prop</th>
        <th class="py-2 pr-4 font-semibold">Type</th>
        <th class="py-2 pr-4 font-semibold">Default</th>
        <th class="py-2 font-semibold">Description</th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((p) => (
          <tr class="border-b border-[color:var(--jolt-border)]">
            <td class="py-2 pr-4 font-mono text-[var(--jolt-accent)]">{p.name}</td>
            <td class="py-2 pr-4 font-mono text-[var(--jolt-text-muted)]">{p.type}</td>
            <td class="py-2 pr-4 font-mono text-[var(--jolt-text-muted)]">
              {p.default ?? 'required'}
            </td>
            <td class="py-2 text-[var(--jolt-text-muted)]">{p.description}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</section>
