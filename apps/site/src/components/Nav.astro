---
import ThemeToggle from './ThemeToggle.astro';
import Search from './Search.astro';

interface Props {
  /** Tailwind max-width class, shared with the content column so the nav aligns with it. */
  maxW?: string;
}
const { maxW = 'max-w-[84rem]' } = Astro.props;

const links = [
  { href: '/components', label: 'Components', match: '/components' },
  { href: '/docs/getting-started', label: 'Docs', match: '/docs' },
];
const path = Astro.url.pathname;
---

<header
  data-pagefind-ignore
  data-site-header
  class="site-header sticky top-0 z-20 border-b border-[color:var(--jolt-border)] bg-[var(--jolt-surface)]/85 backdrop-blur-md"
>
  <nav class:list={['mx-auto flex items-center gap-4 px-4 py-3 sm:gap-6 sm:px-6 lg:px-8', maxW]}>
    <a href="/" class="group flex items-center gap-2" aria-label="Jolt UI — home">
      <svg
        class="h-5 w-5 text-[var(--jolt-accent)] transition-transform group-hover:scale-110"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M13 2 4 13.5h6L9 22l9-11.5h-6L13 2Z"></path>
      </svg>
      <span class="font-display text-base font-semibold tracking-tight">Jolt UI</span>
    </a>
    <ul class="flex items-center gap-1 text-sm">
      {
        links.map((l) => {
          const active = path.startsWith(l.match);
          return (
            <li>
              <a
                href={l.href}
                aria-current={active ? 'page' : undefined}
                class:list={[
                  'rounded-[var(--radius-jolt-sm)] px-2.5 py-1.5 transition-colors',
                  active
                    ? 'font-medium text-[var(--jolt-text)]'
                    : 'text-[var(--jolt-text-subtle)] hover:text-[var(--jolt-text)]',
                ]}
              >
                {l.label}
              </a>
            </li>
          );
        })
      }
    </ul>
    <div class="ml-auto flex items-center gap-2">
      <div class="hidden sm:block"><Search /></div>
      <ThemeToggle />
    </div>
  </nav>
  <span class="nav-progress" aria-hidden="true" data-nav-progress></span>
</header>

<style>
  /* A hairline reading-progress bar riding the header's bottom edge. */
  .nav-progress {
    position: absolute;
    left: 0;
    bottom: -1px;
    height: 2px;
    width: 100%;
    background: linear-gradient(90deg, var(--jolt-accent), var(--jolt-spark));
    transform: scaleX(0);
    transform-origin: left;
    pointer-events: none;
  }
  /* Hide-on-scroll is a motion-mode enhancement (the script also gates itself). */
  @media (prefers-reduced-motion: no-preference) {
    .site-header {
      transition: transform 0.35s var(--ease-jolt-out);
    }
    .site-header[data-hidden] {
      transform: translateY(-100%);
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('[data-site-header]');
  const progress = document.querySelector<HTMLElement>('[data-nav-progress]');
  const motionOk = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let lastY = window.scrollY;
  let ticking = false;

  const apply = () => {
    ticking = false;
    const y = window.scrollY;
    const max = document.documentElement.scrollHeight - window.innerHeight;
    if (progress) progress.style.transform = `scaleX(${max > 0 ? Math.min(1, y / max) : 0})`;
    if (header && motionOk) {
      // Hide going down (past the header's own height buffer), reveal going up or near top.
      if (y > lastY && y > 200) header.dataset.hidden = '';
      else delete header.dataset.hidden;
    }
    lastY = y;
  };

  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(apply);
      }
    },
    { passive: true },
  );
  apply();
</script>
