---
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '/components', label: 'Components', match: '/components' },
  { href: '/docs/getting-started', label: 'Docs', match: '/docs' },
];
const path = Astro.url.pathname;
---

<header
  data-pagefind-ignore
  class="sticky top-0 z-20 border-b border-white/10 bg-[var(--jolt-surface)]"
>
  <nav class="mx-auto flex max-w-5xl items-center gap-6 px-6 py-3">
    <a href="/" class="font-bold tracking-tight">Jolt UI</a>
    <ul class="flex items-center gap-4 text-sm">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                'transition hover:opacity-100',
                path.startsWith(l.match) ? 'opacity-100' : 'opacity-60',
              ]}
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
    <div class="ml-auto flex items-center gap-3">
      <slot name="search" />
      <ThemeToggle />
    </div>
  </nav>
</header>
