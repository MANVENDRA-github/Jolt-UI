---
import { orderedComponents } from '../../lib/categories';

const count = orderedComponents().length;
---

<section id="final-cta" class="cta">
  <div class="inner mx-auto w-full max-w-[84rem] px-4 sm:px-6 lg:px-8">
    <h2 class="cta-title">Start shipping <span class="grad">motion</span>.</h2>
    <div class="cta-row">
      <a href="/components" class="cta-primary">Browse {count} components →</a>
      <a href="/docs/getting-started" class="cta-ghost">Read the docs</a>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    z-index: 1;
    padding-block: clamp(6rem, 16vh, 11rem);
    text-align: center;
    background: var(--jolt-surface);
  }
  .cta-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    text-wrap: balance;
  }
  .grad {
    background: linear-gradient(
      100deg,
      var(--color-volt-400),
      var(--color-volt-300) 45%,
      var(--jolt-spark)
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .cta-row {
    margin-top: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    justify-content: center;
  }
  .cta-primary {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-jolt);
    background: var(--jolt-accent);
    color: var(--jolt-accent-contrast);
    padding: 0.7rem 1.3rem;
    font-weight: 600;
    font-size: 0.9375rem;
    box-shadow: var(--shadow-jolt-glow-lg);
    transition:
      background 0.15s,
      transform 0.15s;
  }
  .cta-primary:hover {
    background: var(--jolt-accent-hover);
    transform: translateY(-1px);
  }
  .cta-ghost {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-jolt);
    border: 1px solid var(--jolt-border-strong);
    padding: 0.7rem 1.3rem;
    font-size: 0.9375rem;
    color: var(--jolt-text-muted);
    transition:
      color 0.15s,
      border-color 0.15s;
  }
  .cta-ghost:hover {
    color: var(--jolt-text);
    border-color: var(--jolt-accent);
  }
</style>
