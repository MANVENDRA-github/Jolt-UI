---
import { orderedComponents, categoriesWithComponents } from '../../lib/categories';

const count = orderedComponents().length;
const cats = categoriesWithComponents();
---

<section id="hero" class="hero">
  <div class="inner mx-auto w-full max-w-[84rem] px-4 sm:px-6 lg:px-8">
    <p class="eyebrow">React · Vue · Svelte — one design language</p>
    <h1 class="headline" data-split-chars>Motion, <span class="grad">tripled</span>.</h1>
    <p class="subhead">
      Polished animated components for <strong>React</strong>, <strong>Vue</strong>, and
      <strong>Svelte</strong> — one design language, kept identical across frameworks by a shared animation
      core and an automated parity gate. Copy-paste or <code>npx jsrepo add</code>.
    </p>
    <div class="cta-row">
      <a href="/components" class="cta-primary">Browse {count} components →</a>
      <a href="/docs/getting-started" class="cta-ghost">npx jsrepo add</a>
    </div>
    <nav class="cat-row" aria-label="Component categories">
      {cats.map((c) => <a href={`/components#${c.slug}`}>{c.label}</a>)}
    </nav>
  </div>
  <div class="scroll-cue" aria-hidden="true">
    <span class="scroll-cue-label">scroll</span>
    <span class="scroll-cue-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    z-index: 1;
    min-height: 100svh;
    display: flex;
    align-items: center;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--jolt-text-subtle);
  }
  .headline {
    margin-top: 1.25rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(3.25rem, 10vw, 7.5rem);
    line-height: 0.98;
    letter-spacing: var(--tracking-display);
    text-wrap: balance;
  }
  .grad {
    background: linear-gradient(
      100deg,
      var(--color-volt-400),
      var(--color-volt-300) 45%,
      var(--jolt-spark)
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .subhead {
    margin-top: 1.5rem;
    max-width: 42rem;
    font-size: clamp(1rem, 1.4vw, 1.125rem);
    line-height: var(--leading-body);
    color: var(--jolt-text-muted);
  }
  .subhead strong {
    color: var(--jolt-text);
    font-weight: 600;
  }
  .subhead code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    padding: 0.05rem 0.35rem;
    border-radius: var(--radius-jolt-sm);
    background: var(--jolt-surface-sunken);
    border: 1px solid var(--jolt-border);
  }
  .cta-row {
    margin-top: 2.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }
  .cta-primary {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-jolt);
    background: var(--jolt-accent);
    color: var(--jolt-accent-contrast);
    padding: 0.7rem 1.3rem;
    font-weight: 600;
    font-size: 0.9375rem;
    box-shadow: var(--shadow-jolt-glow-lg);
    transition:
      background 0.15s,
      transform 0.15s;
  }
  .cta-primary:hover {
    background: var(--jolt-accent-hover);
    transform: translateY(-1px);
  }
  .cta-ghost {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-jolt);
    border: 1px solid var(--jolt-border-strong);
    padding: 0.7rem 1.3rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--jolt-text-muted);
    background: color-mix(in srgb, var(--jolt-abyss) 55%, transparent);
    backdrop-filter: blur(6px);
    transition:
      color 0.15s,
      border-color 0.15s;
  }
  .cta-ghost:hover {
    color: var(--jolt-text);
    border-color: var(--jolt-accent);
  }
  .cat-row {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .cat-row a {
    color: var(--jolt-text-subtle);
    transition: color 0.15s;
  }
  .cat-row a:hover {
    color: var(--jolt-accent);
  }

  .scroll-cue {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .scroll-cue-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--jolt-text-subtle);
  }
  .scroll-cue-line {
    width: 1px;
    height: 2.5rem;
    background: linear-gradient(var(--jolt-accent), transparent);
  }
  @media (prefers-reduced-motion: no-preference) {
    .scroll-cue-line {
      animation: cue-drop 2.2s var(--ease-jolt-out) infinite;
    }
    @keyframes cue-drop {
      0% {
        transform: scaleY(0);
        transform-origin: top;
        opacity: 0;
      }
      35% {
        transform: scaleY(1);
        opacity: 1;
      }
      100% {
        transform: scaleY(1);
        transform-origin: top;
        opacity: 0;
      }
    }
  }
</style>
