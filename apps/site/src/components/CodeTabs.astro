---
import { Code } from 'astro-expressive-code/components';

interface Tab {
  label: string;
  lang: string;
  code: string;
}
interface Props {
  tabs: readonly Tab[];
}
const { tabs } = Astro.props;
---

<div class="jolt-tabs">
  <div class="jolt-tablist" role="tablist">
    {
      tabs.map((tab, i) => (
        <button type="button" role="tab" class="jolt-tab" data-index={i} aria-selected={i === 0}>
          {tab.label}
        </button>
      ))
    }
  </div>
  {
    tabs.map((tab, i) => (
      <div class="jolt-panel" data-index={i} hidden={i !== 0}>
        <Code code={tab.code} lang={tab.lang} />
      </div>
    ))
  }
</div>

<style>
  .jolt-tablist {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
  }
  .jolt-tab {
    cursor: pointer;
    border-radius: var(--radius-jolt-sm);
    padding: 0.25rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--jolt-text-subtle);
    border: 1px solid transparent;
    transition:
      color 0.15s,
      background 0.15s,
      border-color 0.15s;
  }
  .jolt-tab:hover {
    color: var(--jolt-text);
  }
  .jolt-tab[aria-selected='true'] {
    color: var(--jolt-text);
    background: var(--jolt-surface-raised);
    border-color: var(--jolt-border);
  }
</style>

<script>
  for (const tabs of document.querySelectorAll('.jolt-tabs')) {
    const buttons = tabs.querySelectorAll('.jolt-tab');
    const panels = tabs.querySelectorAll('.jolt-panel');
    for (const button of buttons) {
      button.addEventListener('click', () => {
        const index = button.getAttribute('data-index');
        for (const b of buttons) {
          b.setAttribute('aria-selected', String(b.getAttribute('data-index') === index));
        }
        for (const p of panels) {
          p.toggleAttribute('hidden', p.getAttribute('data-index') !== index);
        }
      });
    }
  }
</script>
