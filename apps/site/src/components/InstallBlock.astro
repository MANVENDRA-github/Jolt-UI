---
import CodeTabs from './CodeTabs.astro';
import { installInfo } from '@jolt/core';

// One source for every component's Installation section: the dependency badges and
// the npm/pnpm install tabs are derived from the component's `meta` (its id + deps),
// so they can never drift from what `jsrepo add` actually pulls. Pass any component's
// `<id>Meta`.
interface Props {
  meta: { id: string; deps: readonly string[] };
}
const { meta } = Astro.props;
const { tabs, peers } = installInfo(meta, 'react');
---

<section class="mt-12">
  <h2 class="font-display text-xl font-semibold">Installation</h2>
  <p class="mt-2 text-sm text-[var(--jolt-text-subtle)]">
    Adds the component plus its bundled core. Swap <code
      class="rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono">react</code
    > for <code class="rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono">vue</code> or
    <code class="rounded bg-[var(--jolt-surface-sunken)] px-1 font-mono">svelte</code>.
  </p>
  <div class="mt-3 flex flex-wrap items-center gap-2">
    <span class="font-mono text-xs uppercase tracking-widest text-[var(--jolt-text-subtle)]"
      >Dependencies</span
    >
    {
      peers.map((dep) => (
        <span
          data-testid="dependency-badge"
          class="rounded-[var(--radius-jolt-sm)] border border-[color:var(--jolt-border-strong)] px-2 py-1 font-mono text-xs text-[var(--jolt-text-muted)]"
        >
          {dep}
        </span>
      ))
    }
  </div>
  <div class="mt-3"><CodeTabs tabs={tabs} /></div>
</section>
