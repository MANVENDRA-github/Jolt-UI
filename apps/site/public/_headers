# Cloudflare Pages headers (https://developers.cloudflare.com/pages/configuration/headers/).
# Copied to the build root by Astro and applied at the edge.

# Content-hashed Astro assets never change — cache them hard.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# The jsrepo registry payloads and the Pagefind index are regenerated each build
# under stable names — cache briefly so updates propagate.
/r/*
  Cache-Control: public, max-age=3600
/pagefind/*
  Cache-Control: public, max-age=3600

# Baseline security headers for every response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
